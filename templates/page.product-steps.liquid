{% render 'styles-product-landing-page-min' %}
{% render 'page-product-steps-styles-min' %}
{% render 'fonts-trustpilot' %}
{%- assign product = all_products[page.metafields.custom.product] -%}
{%- assign items = product.metafields.custom.form_settings.value -%}
{% if custom.show_page_content == true %}
    <div class="page-width">
        <header class="section-header text-center">
            <h1 class="section-header__title h2 font-title">{{ page.title }}</h1>
        </header>
        <div class="grid">
            <div class="grid__item medium-up--four-fifths medium-up--push-one-tenth">
                <div class="rte font-description">
                    {{ page.content }}
                </div>
            </div>
        </div>
    </div>
    {% endif %}
<div class="form-container">
    <div class="section-mosaic">
        <div class="mosaic-block block-image-left">
            <div class="mosaic-block__content">
                <div class="mosaic-block__content-wrapper">
                    {% if page.metafields.custom.product_title != blank %}
                        <p class="feature-row__heading h3 separator section-title font-title"
                           data-animate>{{ page.metafields.custom.product_title }}</p>
                    {% endif %}
                    {% if page.metafields.custom.product_description != blank %}
                        <div class="rte-setting featured-row__subtext section-description font-description">{{ page.metafields.custom.product_description }}</div>
                    {% endif %}
                    <!-- TrustBox widget - Mini -->
                  <div class="trustpilot-widget" data-locale="en-GB" data-template-id="53aa8807dec7e10d38f59f32" data-businessunit-id="5fbebb2d281b010001718c1c" data-style-height="112px" data-style-width="200px" data-theme="light">
                    <a href="https://uk.trustpilot.com/review/legitgrails.com" target="_blank" rel="noopener">Trustpilot</a>
                  </div>
                  <!-- End TrustBox widget -->
                </div>
            </div>
            <div class="mosaic-block__image">
                {% if page.metafields.custom.product_image != blank %}
                    <div class="mosaic-image lazyload" data-sizes="auto"
                         style="background-image: url({{ page.metafields.custom.product_image | img_url: 'master' }})"></div>
                {% else %}
                    <div class="mosaic-image">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

