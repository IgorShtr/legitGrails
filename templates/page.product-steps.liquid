{%- if page.metafields.custom.product_title != blank or page.metafields.custom.product_description -%}
    <script>
        (function () {
            const productCardTitle = document.querySelector('.product_card-title');
            const title = '{{ page.metafields.custom.product_title }}'
            const description = '{{ page.metafields.custom.product_description }}'
            if (title.trim().length) {
                productCardTitle.innerHTML = title
            }
            if (description.trim().length) {
                let paragraph = document.createElement('p')
                paragraph.className = 'product_card-description'
                paragraph.innerText = description
                productCardTitle.after(paragraph)
            }
        })();
    </script>
{%- endif -%}
