{% endif %}

<style>
  .tab-section__content:hover {
    cursor: unset;
}
  .tab-section__image-container:hover {
    cursor: pointer;
}
    .scroll-container.upload-options {
      display: flex;
      flex-wrap: wrap;
      width: 300px;
    }
    .radio-option-type {
      width: 100%
    }
  .mfp-wrap {
    z-index: 10000;
    background: rgb(0, 0, 0, 0.5);
  }
  .mfp-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mfp-content {
    width: max-content!important;
    height: max-content!important;
    min-height: auto!important;
  }
  .mfp-content div {
        width: max-content!important;
    border-radius: 30px!important;
    border: 1px solid #C6BA7B!important;
    background: #FFF;
    padding: 15px;
    height: max-content;
    min-height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mfp-content div img {
    border-radius: 20px;
  }
  .mfp-close-btn-in .mfp-close {
    color: #000;
    opacity: 1;
    font-size: 56px;
    margin-top: 20px;
    margin-right: 20px;
    font-weight: 300;
    font-family: 'Open Sans';
}
  a.tab-section_example.popup {
    color: #C6BA7B;
    text-align: center;
    font-family: "Open Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    text-decoration: none;
    margin-top: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
}
  a.tab-section_example.popup:hover {
    text-decoration: underline;
  }
  a.tab-section_example.popup svg {
    display: block;
    margin-right: 5px;
}

  @media(max-width: 1340px) {
    .scroll-container.upload-options {
      width: 210px
    }
    .tip-section {
      gap: 15px;
    }
    .tip-section__content {
      padding: 12px;
    }
  }
  @media(max-width: 1000px) {
    .scroll-container.upload-options {
      width: 100%;
    }
  }
  @media(max-width: 700px) {
    .mfp-content div {
    width: 320px!important;
    padding: 8px!important;
}
    .mfp-close-btn-in .mfp-close {
    color: #000;
    opacity: 1;
    font-size: 50px;
    margin-top: 10px;
    margin-right: 10px;
    font-weight: 300;
    font-family: 'Open Sans';
}
    a.tab-section_example.popup {
      font-size: 14px;
    }
  }
  </style>

