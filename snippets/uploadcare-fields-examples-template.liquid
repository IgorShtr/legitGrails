{% assign items = product.metafields.test.form_settings.value %}
{% for tag in product.tags %}
  {% assign tag_split = tag | split: '_' %}
  {% if tag_split.first == 'type' %}
    {% assign type = tag_split.last %}
  {% endif %}
{% endfor %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/magnific-popup.min.css" integrity="sha512-+EoPw+Fiwh6eSeRK7zwIKG2MA8i3rV/DGa3tdttQGgWyatG/SkncT53KHQaS5Jh9MNOT3dmFL0FjTY08And/Cw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<div
  id="product-uploads"
  class="popup-overlay popup-overlay-u hidden {% if product.tags contains "form-cart"%} form-cart{% endif %}"
  data-type="{{ type }}"
>
  <div class="popup-container popup-container-u transparent">
    <div class="container-popup-header">
      <a class="popup-btn__close"></a>
    </div>
    <div class="popup-sections">
      <div class="popup-sections__row">
        <div class="form-block step-first">
          <div class="form-block__title">Step 1</div>
          <div class="form-block__description">Choose your item</div>
          <div class="form-block__content">
            <div class="scroll-container upload-options upload-options-u">
              {% for item in items %}
                {% unless item.name == 'belt' %}
                  <div class="radio-option-type option-{{ item.name }}">
                    <label class="radio radio-wrap" for="{{ item.name }}">
                      <span>{{ item.title }}</span>
                      <input
                        id="{{ item.name }}"
                        class="radio-option-input"
                        type="radio"
                        name="types"
                        {% if forloop.index == 1 %}
                          checked
                        {% endif %}
                      >
                      <div class="checkmark"></div>
                    </label>
                  </div>
                {% endunless %}
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="form-block block-tips">
          <div class="form-block__title">Tips on how to speed up your authentication</div>
          <div class="form-block__content">
            <div class="tips">
              {% for item in items %}
                <div class="tip-section {% if forloop.index == 1 %} tip-active {% endif %}" id="tip-{{ item.name }}">
                  {% for tip in item.tips limit: 3 %}
                    <div class="tip-section__content">
                      <div class="tip-section__text">
                        {{ tip }}
                      </div>
                    </div>
                  {% endfor %}
                  <div class="tip-section__content">
                    <div class="tip-section__text">
                      Explore model specific
                      <a
                        href="https://legitgrails.frontkb.com/en/categories/604802-general-photos"
                        target="_blank"
                        >photo examples</a
                      >
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
      <div class="popup-sections__row">
        <div class="form-block form-block-tabs">
          <div class="form-block__title">Step 2</div>
          <div class="form-block__description">
            Upload the photos of your <span id="collection-title" class="form-block__item-title">item</span> one by one
          </div>
          <div class="tabs tabs-u">
            {% for tab in items %}
              <div
                class="tab-section tab-section-u {% if forloop.index == 1 %} tab-active {% endif %}"
                id="tab-{{ tab.name }}"
              >
                {% assign types = tab.types %}
                {% assign sorted_types = types | sort: 'required' %}
                {% for type in sorted_types %}
                  <div
                    id="{{ tab.name }}_{{ type.name }}"
                    class="tab-section__content tab-section-u__content tab-{{ type.name }} {% if type.required == "true" %} item-required {% endif %}"
                  >
                    <div
                      id="counter-tab-{{ tab.name }}_{{ type.name }}"
                      class="tab-section__counter"
                    ></div>
                    <div class="tab-section__image-container">
                      {% if type.image.size > 0 %}
                        <div
                          class="tab-section__image"
                          style="background-image: url({{ type.image | asset_url }})"
                        ></div>
                      {% else %}
                        <div class="tab-section__image" style="background-image: url({{ type.image_url }})"></div>
                      {% endif %}
                      <!--
                        <div
                          class="tab-section__image"
                          {% if type.image.size > 0 %}
                            style="background-image: url({{ type.image }})"
                          {% endif %}
                        ></div>
                      -->
                      {% if type.success_image.size > 0 %}
                        <div
                          class="tab-section__image-success"
                          style="background-image: url({{ type.success_image | asset_url }})"
                        ></div>
                      {% else %}
                        <div
                          class="tab-section__image-success"
                          style="background-image: url({{ type.image_url }}); background-color: #c7f5cb; background-blend-mode: luminosity; -webkit-background-blend-mode: luminosity; -moz-background-blend-mode: luminosity; -ms-background-blend-mode: luminosity; -o-background-blend-mode: luminosity;"
                        ></div>
                      {% endif %}
                      <!--
                        <div
                          class="tab-section__image-success"
                          {% if type.success_image.size > 0 %}
                            style="background-image: url({{ type.success_image }}); background-color: #c7f5cb; background-blend-mode: luminosity; -webkit-background-blend-mode: luminosity; -moz-background-blend-mode: luminosity; -ms-background-blend-mode: luminosity; -o-background-blend-mode: luminosity;"
                          {% endif %}
                        ></div>
                      -->

                      <div class="loader-line">
                        <i class="loader spin"></i>
                      </div>
                    </div>
                    <div class="tab-section__title">
                      {{ type.title }}
                    </div>
                  {% if product contains "example-images" %}
                    {% if type.example_image > 0 %}
                      <a href="#example-{{ tab.name }}_{{ type.name }}" class="tab-section_example popup">
                      <svg width="14" height="13" viewBox="0 0 14 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.00188 4.41598C6.82188 4.41598 6.67521 4.36264 6.56188 4.25598C6.45521 4.14264 6.40188 3.99598 6.40188 3.81598C6.40188 3.63598 6.45521 3.49264 6.56188 3.38598C6.67521 3.27264 6.82188 3.21598 7.00188 3.21598C7.18188 3.21598 7.32521 3.27264 7.43188 3.38598C7.54521 3.49264 7.60188 3.63598 7.60188 3.81598C7.60188 3.99598 7.54521 4.14264 7.43188 4.25598C7.32521 4.36264 7.18188 4.41598 7.00188 4.41598ZM7.40188 5.37598V10.376H6.60188V5.37598H7.40188Z" fill="#C6BA7B"/>
                      <circle cx="7" cy="6.5" r="6" stroke="#C6BA7B"/>
                      </svg>
                      Example
                    </a>
                    {% endif %}
                  {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <p class="cart-attribute__field uploader-dawn hidden">
        <input
          id="uploader"
          type="hidden"
          data-images-only="true"
          data-multiple="true"
          role="uploadcare-uploader"
          name="properties[Upload]"
        >
      </p>
      <div class="popup-sections__row">
        <div class="buttton-wrap">
          <div id="upload-messages" class="upload-messages"></div>
          {% if product.tags contains 'form-cart' %}
            <button id="upladcare-cart" class="btn main-btn disabled" name="" style="max-width: 250px">
              <span>Submit</span>
            </button>
          {% else %}
            <button id="upload_submit" class="btn main-btn disabled" name="" style="max-width: 250px">
              <span>Submit</span>
            </button>
          {% endif %}
        </div>
      </div>
      <div class="popup-sections__row">
        <p class="popup-terms">
          By submitting an order you agree with the
          <a href="https://legitgrails.com/policies/terms-of-service" target="_blank">Terms and Conditions</a> and
          <a href="https://legitgrails.com/policies/refund-policy" target="_blank">Refund policy</a>
        </p>
      </div>
    </div>
  </div>
</div>
<div class="hidden uploadcare-product-hidden" id="product-data" data-product="{{ product | json | escape }}">
  {{ product.id }}
</div>

{% if product contains "example-images" %}
{% for tab in items %}              
  {% assign types = tab.types %}
                {% assign sorted_types = types | sort: 'required' %}
                {% for type in sorted_types %}
<div class="hidden">
    <div id="example-{{ tab.name }}_{{ type.name }}">
      <img src="type.example_image" class="example-popup-img">
    </div>
</div>
{% endfor %}
{% endfor %}
{% endif %}

                        
{% for variant in product.variants %}
  {% if forloop.index == 1 %}
    <input id="selected-variant" class="hidden" type="hidden" value="{{ variant.id }}">
  {% endif %}
{% endfor %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/jquery.magnific-popup.min.js" integrity="sha512-IsNh5E3eYy3tr/JiX2Yx4vsCujtkhwl7SLqgnwLNgf04Hrt9BT9SXlLlZlWx+OK4ndzAoALhsMNcCmkggjZB1w==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        <script>
          $('.popup').magnificPopup();
        </script>

          
<script src="https://ucarecdn.com/libs/widget/3.x/uploadcare.full.min.js"></script>
<script>
    UPLOADCARE_PUBLIC_KEY = "ad3d10f764f69a907860";
