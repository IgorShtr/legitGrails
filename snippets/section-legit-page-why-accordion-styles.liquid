<style>
.accordion-section .section-description{margin-bottom:50px}.accordion-card{margin-bottom:20px;overflow:hidden}.accordion-card a,.accordion-card a:active,.accordion-card a:hover{color:#cbad73}.accordion-card__heading{position:relative;cursor:pointer;z-index:2;background-color:#cbad73;color:#fff;padding:19px 26px;display:flex;align-items:center;justify-content:space-between;border-radius:5px;transition:.3s}.accordion-card__heading:hover{box-shadow:0 2px 8px rgba(1,1,1,.3)}.accordion-card__title{font-weight:600;font-size:16px;line-height:22px;color:#fff}.accordion-card.active .accordion-card__heading .accordion-card__arrow{transform:rotate(180deg)}
.accordion-card__arrow {
width: 22px;
height: 22px;
background-image: url({{ 'arrow.svg' | asset_url }});
transition: transform .4s ease;
background-position: center;
background-repeat: no-repeat;
}
.accordion-card__content{transition:height .6s}.accordion-card__content.expand div{opacity:1;transition:opacity .2s .4s}.accordion-card__content div{padding-top:15px;height:auto;opacity:0;transition:opacity .3s;font-weight:400;font-size:17px;color:#161616;line-height:1.6}.text-center{text-align:center}@media (min-width:1024px){.accordion-card__heading{min-height:60px}.accordion-card__title{font-size:19px}}
</style>
