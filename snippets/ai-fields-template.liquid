<style>
    .tooltip-fast {
        position: absolute;
        top: 5px;
        left: 10px;
        z-index: 100;
        background-color: white;
        padding: 3px 8px;
        max-width: 143px;
        border: 1px solid black;
        border-radius: 12px;
        font-family: "Open Sans", sans-serif;
        color: black;
        font-size: 11px;
        line-height: 13px;
        font-weight: 400;
        margin: 0px;

        display: none;
    }

    /* For screens smaller than 769px */
    @media (max-width: 768px) {
        .tooltip-fast {
            left: 5px;
            max-width: 109px;
        }

        .tooltip-fast .tooltip-text {
            display: inline;
        }

        .tooltip-fast .tooltip-icon {
            display: none;
        }
    }

    /* For screens 769px and larger */
    @media (min-width: 769px) {
        .tooltip-fast .tooltip-text {
            display: none;
            transition: display 0.3s ease;
        }

        .tooltip-fast .tooltip-icon {
            display: inline;
            transition: display 0.3s ease;
        }

        .tooltip-fast:hover .tooltip-text {
            display: block;
        }

        .tooltip-fast:hover .tooltip-icon {
            display: none;
        }
    }

    /* Define the keyframes animation */
    @keyframes gradientAnimation {
      to {
        background-position-x: -20%;
      }
    }

    /* Apply the animation to the .blinking class */
    .blinking {
      background: linear-gradient(
        100deg,
        rgba(255, 255, 255, 0) 40%,
        rgba(255, 255, 255, 0.5) 50%,
        rgba(255, 255, 255, 0) 60%
      );
      background-size: 200% 100%;
      background-position-x: 180%;
      animation: gradientAnimation 1s ease-in-out infinite;
    }
  }
</style>

