{% assign items = product.metafields.test.form_settings.value %}
{% assign fastProductItem = product.metafields.test.fast_check.value %}
{% for tag in product.tags %}
  {% assign tag_split = tag | split: '_' %}
  {% if tag_split.first == 'type' %}
    {% assign type = tag_split.last %}
  {% endif %}
{% endfor %}
<div
  id="product-uploads"
  class="popup-overlay hidden {% if product.tags contains "form-cart" %} form-cart{% endif %}"
  data-type="{{ type }}"
>
  <div class="popup-container transparent">
    <div class="container-popup-header">
      <a class="popup-btn__close"></a>
    </div>
    <div class="popup-sections">
      <div class="popup-sections__row">
        <div class="form-block step-first">
          <div class="form-block__title">Step 1</div>
          <div class="form-block__description">Choose your item</div>
          <div class="form-block__content">
            <div class="scroll-container upload-options">
              {% for fastItem in fastProductItem[0].categories %}
                <div class="radio-option-type option-{{ fastItem.id }}">
                  <label class="radio radio-wrap" for="{{ fastItem.id }}">
                    <span>{{ fastItem.name }}</span>
                    <input
                      id="{{ fastItem.id }}"
                      class="radio-option-input"
                      type="radio"
                      name="types"
                      {% if forloop.index == 1 %}
                        checked
                      {% endif %}
                    >
                    <div class="checkmark"></div>
                  </label>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="form-block block-tips">
          <div class="form-block__title">Tips on how to speed up your authentication</div>
          <div class="form-block__content">
            <div class="tips">
              <div class="tip-section tip-active" id="tip-custom">
                {% assign customTips = 'Take close-up and focused photos in natural light,Focus the camera on the area under the insole'
                  | split: ','
                %}
                {% for tip in customTips %}
                  <div class="tip-section__content">
                    <div class="tip-section__text">
                      {{ tip }}
                    </div>
                  </div>
                {% endfor %}
                <div class="tip-section__content">
                  <div class="tip-section__text">
                    Explore model specific
                    <a
                      href="https://legitgrails.zendesk.com/hc/en-us/categories/5306328467345-Photos-Needed-for-Authentication"
                      target="_blank"
                      >photo examples</a
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional step for fastProductItem selection -->
      {% for fastItem in fastProductItem[0].categories %}
        <div id="additional-step-{{ fastItem.id }}" class="{% if forloop.first %}visible{% else %}hidden{% endif %}">
          <div class="form-block step-additional">
            <div class="form-block__title">Step 2</div>
            <div class="form-block__description">
              Choose a model from the dropdown or <b>All series</b> option if you can’t find your model.
            </div>
            <div class="form-block__content">
              <div class="scroll-container model-options">
                <!-- Display models for the selected fast item category -->
                <div class="select-option-model" style="width: 220px;">
                  <select id="{{ fastItem.id }}_model" name="models" style="border: 1px solid #cdab71;">
                    {% for model in fastItem.models %}
                      <option
                        value="{{ model.id }}"
                        {% if forloop.first %}
                          selected
                        {% endif %}
                      >
                        {{ model.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
      <!-- End of additional step -->

      <div class="popup-sections__row">
        <div class="form-block form-block-tabs">
          <div class="form-block__title">Step 3</div>
          <div class="form-block__description">
            Upload the photos of your <span id="collection-title" class="form-block__item-title">item</span> one by one.
          </div>

          <div class="tabs">
            {% assign first_model = true %}
            {% for category in fastProductItem[0].categories %}
              {% for model in category.models %}
                <div
                  class="tab-section{% if first_model %} tab-active{% endif %}"
                  id="tab-{{ category.id }}_{{ model.id }}"
                >
                  {% assign indexes = model.indexes %}
                  {% for index in indexes %}
                    <label
                      for="{{ category.id }}_{{ model.id }}_{{ index.point_id }}"
                      class="tab-section__content tab-{{ index.point_id }}"
                    >
                      <div
                        id="counter-tab-{{ category.id }}_{{ model.id }}_{{ index.point_id }}"
                        class="tab-section__counter"
                      ></div>
                      <div class="tab-section__image-container blinking">
                        <div
                          class="tab-section__image"
                          data-src="{{ index.example_img }}"
                        ></div>
                        <!-- Success image -->
                        <div
                          class="tab-section__image-success"
                          style="background-color: rgba(59, 249, 76, 0.5); height: 100%; background-position: center; background-size: contain; visibility: hidden;"
                        ></div>
                        <!-- Reject image -->
                        <div
                          class="tab-section__image-reject"
                          style="
                            background-color: rgba(255, 5, 5, 0.5);
                            height: 100%;
                            background-position: center;
                            background-size: contain;
                            visibility: hidden;
                            bottom: 0;
                            left: 0;
                            position: absolute;
                            right: 0;
                            top: 0;
                            width: 100%;
                          "
                        ></div>

                        <!-- Tooltip element -->
                        <div class="tooltip-fast tooltip-fast-error">
                          <i class="tooltip-icon">i</i>
                          <span class="tooltip-text"
                            >Please submit a new photo, ensuring it's clear and captures the specific part of the item
                            in question.</span
                          >
                        </div>
                        <!-- Tooltip image size element -->
                        <div class="tooltip-fast tooltip-fast-size">
                          <i class="tooltip-icon">i</i>
                          <span class="tooltip-text"
                            >Something went wrong, please try uploading the same photo again.</span
                          >
                        </div>

                        <!-- Loader element -->
                        <div
                          class="loader-line"
                          style="position: absolute; top: 0; left: 0; width: 100%; background: rgba(0, 0, 0, 0.4);"
                        >
                          <i class="loader spin"></i>
                        </div>
                      </div>

                      <div class="tab-section__title">
                        {{ index.point_name -}}
                        {%- if index.required == true -%}
                          <span style="color: red;"> *</span>
                        {%- endif %}
                      </div>

                      <input
                        class="file-input-fast-check"
                        id="{{ category.id }}_{{ model.id }}_{{ index.point_id }}"
                        {% if index.required == true %}
                          required
                        {% endif %}
                        type="file"
                        hidden
                        accept=".png,.jpg,.jpeg,.heic,.heif"
                      >
                    </label>
                  {% endfor %}
                </div>
                {% if first_model %}
                  {% assign first_model = false %}
                {% endif %}
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="popup-sections__row">
        <div class="buttton-wrap">
          <div id="upload-messages" class="upload-messages"></div>
          {% if product.tags contains 'form-cart' %}
            <button id="upladcare-cart" class="btn main-btn disabled" name="" style="max-width: 250px">
              <span>Submit</span>
            </button>
          {% else %}
            <button id="upload_submit" class="btn main-btn disabled" name="" style="max-width: 250px">
              <span>Submit</span>
            </button>
          {% endif %}
        </div>
      </div>
      <div class="popup-sections__row">
        <p class="popup-terms">
          By submitting an order you agree with the
          <a href="https://legitgrails.com/policies/terms-of-service" target="_blank">Terms and Conditions</a> and
          <a href="https://legitgrails.com/policies/refund-policy" target="_blank">Refund policy</a>
        </p>
      </div>
    </div>
  </div>
</div>
<div class="hidden uploadcare-product-hidden" id="product-data" data-product="{{ product | json | escape }}">
  {{ product.id }}
</div>
{% for variant in product.variants %}
  {% if forloop.index == 1 %}
    <input id="selected-variant" class="hidden" type="hidden" value="{{ variant.id }}">
  {% endif %}
{% endfor %}

<script>
  // Check if the browser supports Intersection Observer
  if (!('IntersectionObserver' in window)) {
      // If not, load the polyfill dynamically
      const script = document.createElement('script');
      script.src = 'https://polyfill.io/v3/polyfill.min.js?features=IntersectionObserver';
      script.async = true;
      document.head.appendChild(script);
  }
</script>

