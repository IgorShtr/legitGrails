<script>
  $(window).on('load', function () {
    var winScrollTop = $(this).scrollTop();
    let window_height = window.innerHeight
    let screen1 = document.querySelector('.cosmetics_hero')
    let screen2 = document.querySelector('.cosmetics_steps')
    let screen3 = document.querySelector('.cosmetics_coverage')
    let screen4 = document.querySelector('.cosmetics-landing_authentication')
    let screen5 = document.querySelector('.cosmetics_cta')
    let screen1_scrolled = false
    let screen2_scrolled = false
    let screen3_scrolled = false
    let screen4_scrolled = false


    if (winScrollTop > screen1.offsetHeight - 200 && !screen1_scrolled) {
        cosmeticsStepsLoad();
        screen1_scrolled = true;
    };
    if (winScrollTop > screen2.offsetHeight + 400 && !screen2_scrolled) {
        cosmeticsCoverageLoad();
        screen2_scrolled = true;
    };
    if (winScrollTop > screen3.offsetHeight + 800 && !screen3_scrolled) {
        cosmeticsAuthenticationLoad();
        screen3_scrolled = true;
    };
    if (winScrollTop > screen4.offsetHeight + 1200 && !screen4_scrolled) {
        cosmeticsCtaLoad();
        screen4_scrolled = true;
    };

    window.addEventListener('scroll', () => {
        if (screen2.offsetTop + 400 < window.pageYOffset + window_height && !screen1_scrolled) {
            cosmeticsStepsLoad();
            screen1_scrolled = true;
        };
        if (screen3.offsetTop + 400 < window.pageYOffset + window_height && !screen2_scrolled) {
            cosmeticsCoverageLoad();
            screen2_scrolled = true;
        };
      if (screen4.offsetTop + 400 < window.pageYOffset + window_height && !screen3_scrolled) {
            cosmeticsAuthenticationLoad();
            screen3_scrolled = true;
        };
      if (screen5.offsetTop + 100 < window.pageYOffset + window_height && !screen4_scrolled) {
            cosmeticsCtaLoad();
            screen4_scrolled = true;
        };
    });

});

function cosmeticsStepsLoad() {
    $('.cosmetics_steps-line').addClass('animated');
    $('.cosmetics_steps-line-item-wrapp-1').addClass('animated');
    $('.cosmetics_steps-item-1').addClass('animated');
    setTimeout(function () {
        $('.cosmetics_steps-line-item-wrapp-2').addClass('animated');
        $('.cosmetics_steps-item-2').addClass('animated');
    }, 500);
    setTimeout(function () {
          $('.cosmetics_steps-line-item-wrapp-3').addClass('animated');
          $('.cosmetics_steps-item-3').addClass('animated');
      }, 1000);
};
  function cosmeticsCoverageLoad() {
    $('.cosmetics_coverage-item-1').addClass('animated');
    setTimeout(function () {
        $('.cosmetics_coverage-item-2').addClass('animated');
    }, 300);
};
  function cosmeticsAuthenticationLoad() {
if ($(window).width() < 950) {
        $('.product_checkout-right').addClass('animated');
    setTimeout(function () {
        $('.cosmetics-landing_authentication-wrapper-image').addClass('animated');
    }, 500);
    } else {
      $('.cosmetics-landing_authentication-wrapper-image').addClass('animated');
    setTimeout(function () {
        $('.product_checkout-right').addClass('animated');
    }, 500);
    }
};
  function cosmeticsCtaLoad() {
    $('.cosmetics_cta-wrapper').addClass('animated');
};
</script>