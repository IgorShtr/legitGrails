}
  }
  @media(max-width: 750px) {
    .scroll-container .radio-option-type .radio-wrap {
    height: 30px;
    padding: 3px 0 3px 25px;
}
        .tab-section__content {
        flex-basis: calc(33.333334% - 10px) !important;
        min-height: max-content !important;
