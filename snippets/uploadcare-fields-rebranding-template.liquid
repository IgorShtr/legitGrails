      background: #65433E;
    }
  .scroll-container {
    scrollbar-color: #3c1f1b #eeeeee;
    scrollbar-width: thin;
}
    a.tab-section_example {
      text-decoration: none;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 3px;
      justify-content: center;
