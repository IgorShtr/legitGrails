  }
  @media(max-width: 500px) {
    .tab-section__content {
        flex-basis: calc(50% - 7.5px) !important;
        min-height: max-content !important;
        min-width: calc(50% - 7.5px) !important;
        height: max-content !important;
        width: calc(50% - 7.5px) !important;
