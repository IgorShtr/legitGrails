<style>
    ul.statement-ul {
        padding-left: 30px;
    }
</style>

<div class="rebranding_container">
    <div class="block-flex-wrap block-gap-30">
        <div class="block-flex-wrap block-gap-15">
            <h1 class="h1-heading-pp">
                Accessibility Statement
            </h1>
            <p class="body-text">
                LegitGrails is committed to making our app easy to use for everyone, including people with disabilities. We work to follow accessible design practices and improve the experience for all users.
            </p>
        </div>
        <div class="block-flex-wrap block-gap-15">
            <h2 class="h2-heading-pp w-100">
                What we aim to support
            </h2>
            <ul class="statement-ul">
                <li>
                    <p class="body-text">Clear and readable text</p>
                </li>
                <li>
                    <p class="body-text">Simple navigation</p>
                </li>
                <li>
                    <p class="body-text">Screen reader support</p>
                </li>
                <li>
                    <p class="body-text">Proper labels on buttons and icons</p>
                </li>
                <li>
                    <p class="body-text">High-contrast visuals where possible</p>
                </li>
            </ul>
        </div>
        <div class="block-flex-wrap block-gap-15">
            <h2 class="h2-heading-pp">
                Our ongoing efforts
            </h2>
            <p class="body-text">
                We continue to review the app and improve accessibility in future updates. If we release new features, we check that they work well with assistive technologies.
            </p>
        </div>
        <div class="block-flex-wrap block-gap-15">
            <h2 class="h2-heading-pp">
                Feedback
            </h2>
            <p class="body-text">
                If you experience any accessibility issues or have suggestions, please contact us. We review all messages and try to fix problems as quickly as possible.
            </p>
            <p class="body-text">
                Email: <a href="mailto:support@legitgrails.com" style="text-decoration:underline; color:#F24F14;" class="standart-hover">support@legitgrails.com</a>
            </p>
            <p class="body-text">
                If you experience any accessibility issues or have suggestions, please contact us. We review all messages and try to fix problems as quickly as possible.
            </p>
        </div>
    </div>
</div>

{% schema %}
  {
    "name": "Statement",
    "class": "rebranding-section",
    "settings": []
  }
{% endschema %}