        <p class="resalex_offers-item-tag caption">Minimize customer returns</p>
        <p class="resalex_offers-item-tag caption">Eliminate manual condition evaluation</p>
      </div>
      <div class="resalex_offers-item-text">
        <p class="resalex_offers-item-title h3-heading-ss">
          <span class="h3-heading-pp">Consistent, Trustworthy</span><br>Condition Grading
        </p>
        <p class="resalex_offers-item-desc resalex-desc body-text">
          ResaleX assesses each item’s condition, offering a standardized grade
        </p>
      </div>
      <div class="resalex_offers-item-image-wrapp">
        <img src="{{ 'resalex-landing_tool-2.webp' | asset_url }}" loading="lazy" alt="landing_tool-2"  class="resalex_offers-item-image">
      </div>
    </div>
    <div class="resalex_offers-item resalex_offers-item-3">
      <div class="resalex_offers-item-tags">
        <p class="resalex_offers-item-tag caption">Maximize profit</p>
        <p class="resalex_offers-item-tag caption">Stay Competitive with Predictive Pricing</p>
        <p class="resalex_offers-item-tag caption">Increase conversions</p>
      </div>
      <div class="resalex_offers-item-text">
        <p class="resalex_offers-item-title h3-heading-ss">
          Smart Pricing for <span class="h3-heading-pp">Market Advantage</span>
        </p>
        <p class="resalex_offers-item-desc resalex-desc body-text">
          AI-driven pricing recommendations based on current market trends, item classification, and condition.
        </p>
      </div>
      <div class="resalex_offers-item-image-wrapp">
        <div class="resalex_offers-item-image-label resalex_offers-item-image-label-left">
          <p class="resalex_offers-item-image-label-desc">
            2020
          </p>
          <p class="resalex_offers-item-image-label-title">
            $4.800
          </p>
        </div>
        <img src="{{ 'resalex-landing_tool-3.png' | asset_url }}" loading="lazy" alt="landing_tool-3"  class="resalex_offers-item-image">
        <div class="resalex_offers-item-image-label resalex_offers-item-image-label-right">
          <p class="resalex_offers-item-image-label-desc">
            2024
          </p>
          <p class="resalex_offers-item-image-label-title">
            $6.230
          </p>
        </div>
      </div>
      <div class="resalex_offers-item-graphic">
          <div class="resalex_offers-item-image-wrapp-graphic-text block-flex-wrap">
            <p class="small-text">USD 7.500</p>
            <p class="small-text">USD 6.500</p>
            <p class="small-text">USD 5.500</p>
            <p class="small-text">USD 4.500</p>
          </div>
          <svg class="resalex_offers-item-graphic-desktop" width="1400" height="155" viewBox="0 0 1400 155" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="4.37114e-08" y1="0.5" x2="1400" y2="0.500122" stroke="black" stroke-opacity="0.1"/>
          <line x1="4.37114e-08" y1="62.5" x2="1400" y2="62.5001" stroke="black" stroke-opacity="0.1"/>
          <line x1="4.37114e-08" y1="120.5" x2="1400" y2="120.5" stroke="black" stroke-opacity="0.1"/>
          <path d="M134 153L242.5 111.5H330L393 153L488.5 83H570.5L636 52.5L712.5 111.5H823L899.5 18.5H978.5L1037.5 52.5L1123.5 39L1170.5 63H1260.5L1330.5 18.5H1399" stroke="#F24F14" stroke-width="2"/>
          </svg>
        </div>
    </div>
  </div>
</div>

