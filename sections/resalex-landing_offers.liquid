<style>
  .resalex_offers-title {
    text-align: center;
  }
  .resalex_offers-items {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 20px;
  }
  .resalex_offers-item {
    border-radius: 18px;
    border: 1px solid #DADADA;
    padding: 30px 30px 0px 30px;
    text-align: center;
    width: calc(50% - 10px);
    opacity: 1;
    transform: translateY(0px);
    transition: .3s;
    position: relative;
  }
  .resalex_offers-item:last-child {
    width: 100%;
  }
  .resalex_offers-item-tags {
    display: flex;
    flex-wrap: wrap;
    width: 100%; 
    gap: 10px;
    justify-content: center;
  }
  .resalex_offers-item-text {
    margin-top: 20px;
  }
  p.resalex_offers-item-tag {
    display: block;
    border-radius: 20px;
    border: 1px solid #130706;
    padding: 6px 8px;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: -0.4px;
    text-transform: uppercase;
  }
p.resalex_offers-item-desc {
    margin: 15px auto 0 auto;
    max-width: 485px;
  width: 100%;
}
.resalex_offers-item-image-wrapp {
    position: relative;
    width: max-content;
    margin: 20px auto 0 auto;
}
img.resalex_offers-item-image {
    height: 467px;
    margin: 0 auto;
    display: block;
}
  .resalex_offers-item:last-child img.resalex_offers-item-image {
    height: 417px;
    padding-right: 100px;
  }
  .resalex_offers-item:last-child p.resalex_offers-item-desc {
    max-width: 870px;
  }
  .resalex_offers-item-image-label {
    border-radius: 13px;
    border: 1px solid rgba(0, 0, 0, 0.07);
    background: linear-gradient(96deg, rgba(224, 224, 224, 0.03) 23.53%, rgba(189, 189, 189, 0.03) 75.95%);
    box-shadow: 0px 4px 24px -2px rgba(0, 0, 0, 0.10);
    backdrop-filter: blur(20px);
    padding: 15px 20px;
    text-align: center;
    position: absolute;
    top: 50%;
    margin-top: -23.5px;
  }
.resalex_offers-item-image-label-left {
    left: 0;
    margin-left: 10px;
}
.resalex_offers-item-image-label-right {
    right: 0;
    margin-right: 10px;
}
  p.resalex_offers-item-image-label-desc {
    font-size: 22px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.44px;
    margin-bottom: 3px;
  }
  p.resalex_offers-item-image-label-title {
    font-size: 40px;
    font-family: "PP Fragment";
    font-style: normal;
    font-weight: 400;
    line-height: 1; 
  }
  .resalex_offers-item-graphic {
    position: absolute;
    width: 100%;
    bottom: 87px;
    left: 0;
    z-index: -1;
}
.resalex_offers-item-image-wrapp-graphic-text {
    width: 128px;
    gap: 38px;
    padding-left: 20px;
}
  .resalex_offers-item-graphic svg {
    width: 100%;
    position: absolute;
    left: 0;
    top: 37px;
}
.resalex_offers-item-graphic-tablet, .resalex_offers-item-graphic-mobile {
  display: none;
}
  @media(max-width: 1450px) {
    p.resalex_offers-item-tag {
      font-size: 16px;
    }
    .resalex_offers-item-image-wrapp-graphic-text p {
        font-size: 15px;
      line-height: 1;
    }
.resalex_offers-item-image-wrapp-graphic-text {
    gap: 36px;
    padding-left: 15px;
}
    .resalex_offers-item-graphic svg {
    top: 18px;
}
  }
  @media(max-width: 1250px) {
    .resalex_offers-item {
    border-radius: 18px;
    border: 1px solid #DADADA;
    padding: 20px 20px 0px 20px;
    text-align: center;
}
    p.resalex_offers-item-desc {
    margin: 10px auto 0 auto;
}
    img.resalex_offers-item-image {
    height: 350px;
    }
    p.resalex_offers-item-tag {
        font-size: 12px;
    }
    .resalex_offers-item:last-child img.resalex_offers-item-image {
        height: 289px;
        padding-right: 81px;
    }
    p.resalex_offers-item-image-label-desc {
    font-size: 20px;
    }
    p.resalex_offers-item-image-label-title {
    font-size: 30px;
    }
    .resalex_offers-item-image-label-right {
        margin-right: 5px;
    }
    .resalex_offers-item-image-label-left {
        margin-left: -5px;
    }
    .resalex_offers-item-graphic svg {
        top: -4px;
    }
    .resalex_offers-item-image-wrapp-graphic-text {
        gap: 27px;
    }
    .resalex_offers-item-image-wrapp-graphic-text p {
        font-size: 12px;
    }
  }
  @media(max-width: 950px) {
    .resalex_offers-item-image-label-right {
        margin-right: 8px;
    }
    .resalex_offers-item-graphic {
        display: none;
    }
  }
  @media(max-width: 870px) {
    .resalex_offers-item {
      width: 100%;
    }
        p.resalex_offers-item-tag {
        font-size: 14px;
    }
    .resalex_offers-item-text {
    margin-top: 15px;
}
  }
  @media(max-width: 750px) {
    .resalex_offers-items {
      margin-top: 15px;
      gap: 15px;
    }
    .resalex_offers-item {
      padding: 15px 15px 0 15px;
    }
    .resalex_offers-item-image-wrapp {
        margin: 30px auto 0 auto;
    }
    .resalex_offers-item:last-child img.resalex_offers-item-image {
        height: 214px;
        padding-right: 53px;
    }
        img.resalex_offers-item-image {
        height: 300px;
    }
        p.resalex_offers-item-tag {
        font-size: 12px;
    }
    p.resalex_offers-item-image-label-title {
      font-size: 25px;
    }
    p.resalex_offers-item-image-label-desc {
      font-size: 16px;
    }
    .resalex_offers-item-image-label {
      padding: 10px 15px;
    }
    .resalex_offers-item-image-label-right {
        margin-right: -10px;
    }
    .resalex_offers-item-image-label-left {
    left: 0;
    margin-left: -15px;
}
  }
  @media(max-width: 550px) {
    .resalex_offers-item:last-child img.resalex_offers-item-image {
        padding-right: 46px;
    }
    img.resalex_offers-item-image {
        height: 240px;
    }
    p.resalex_offers-item-tag {
        font-size: 10px;
    }
    .resalex_offers-item-tags {
        gap: 5px;
    }
    .resalex_offers-item-image-label-right {
        margin-right: -23px;
    }
    .resalex_offers-item-image-label-left {
        margin-left: -30px;
    }
    .resalex_offers-item:last-child img.resalex_offers-item-image {
        height: 160px;
    }
  }
  @media(max-width: 500px) {
        p.resalex_offers-item-image-label-title {
        font-size: 16px;
    }
        p.resalex_offers-item-image-label-desc {
        font-size: 12px;
    }
        .resalex_offers-item-image-label {
        padding: 7px 12px;
        border-radius: 8px;
    }
        .resalex_offers-item-image-label-right {
        margin-right: 2px;
    }
        .resalex_offers-item-image-label-left {
        margin-left: 3px;
    }
  }
  @media(max-width: 430px) {
        .resalex_offers-item-image-label {
        background: linear-gradient(96deg, rgba(224, 224, 224, 0.33) 23.53%, rgba(189, 189, 189, 0.03) 48.95%);
    }
    .resalex_offers-item-image-label-right {
        margin-right: 0px;
    }
        .resalex_offers-item:last-child img.resalex_offers-item-image {
        padding-right: 29px;
    }
        .resalex_offers-item-image-label-left {
        left: 0;
        margin-left: 4px;
    }
  }
  @media(max-width: 400px) {
    .resalex_offers-item-image-label {
      display: none;
    }
  }
</style>

<div class="rebranding_container">
  <h2 class="resalex_offers-title resalex_section-title h2-heading-ss">
    <span class="h2-heading-pp">AI-driven tool</span> designed to streamline<br><span class="h2-heading-pp">marketplace operations</span>
  </h2>
  <div class="resalex_offers-items">
    <div class="resalex_offers-item resalex_offers-item-1">
      <div class="resalex_offers-item-tags">
        <p class="resalex_offers-item-tag caption">Save Hours of Manual Work</p>
