<style>
  .quarter_offers-items {
    width: 100%;
    justify-content: center;
    gap: 40px 30px;
  }
  .icon-center-item svg {
    height: 56px;
    width: auto;
  }
  @media(max-width: 750px) {
    .icon-center-item svg {
      height: 30px;
    }
    .block-quarter-item {
      gap: 15px;
    }
  }
</style>

