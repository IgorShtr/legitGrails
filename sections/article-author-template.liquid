{% render 'section-article-author-template-styles-min' %}
<div class="article" data-section-id="{{ section.id }}" data-section-type="article-template">
  <div class="rebranding_container">
    <div class="article__wrapper grid">
      <div class="article__content article__content--large grid__item medium-up--ten-twelfths medium-up--push-one-twelfth">
          <h1 class="article__title h2 font-title">{{ article.title }}</h1>
          <div class="article__author-wrapper block-flex-wrap block-gap-15 block-flex-center-start">
            <img class="article__author-img" src="{{ "articles_author-lg-team.webp" | asset_url }}">
            <div class="article__author-text">
              <p class="body-text">Written by</p>
              <p class="body-text block-flex-wrap block-flex-center-start block-gap-5 article__author-text-name">
                <span class="bold">LegitGrails Team</span>
            <a href="https://ee.linkedin.com/company/legitgrails" target="_blank">
