{% render 'section-legit-mosaic-styles' %}
<div class="section-mosaic">
  {% for block in section.blocks %}
  {% assign mod = forloop.index | modulo: 2 %}
    <div class="mosaic-block {% if mod == 0 %}block-image-right{% else %}block-image-left{% endif %}">
      <div class="mosaic-block__content">
        <div class="mosaic-block__content-wrapper">
        {% if block.settings.title != blank %}
          <h2 class="feature-row__heading h3 separator section-title font-title" data-animate>{{ block.settings.title | escape }}</h2>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="rte-setting featured-row__subtext section-description font-description">{{ block.settings.text }}</div>
        {% endif %}
        {% if block.settings.button_label != blank %}
          <a href="{{ block.settings.link }}" class="main-btn font-title">
            {{ block.settings.button_label }}
          </a>
        {% endif %}
        </div>
      </div>
      <div class="mosaic-block__image">
        {% if block.settings.image != blank %}
          <div class="mosaic-image image--{{ section.id }}" style="background-image: url({{ block.settings.image | img_url: 'master' }})"></div>
          <noscript>
            <div class="mosaic-image image--{{ section.id }}" style="background-image: {{ block.settings.image | img_url: 'master' }}"></div>
          </noscript>
        {% else %}
          <div class="mosaic-image image--{{ section.id }}">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Legit Mosaic blocks",
  "class": "section",
  "tag": "section",
  "blocks": [
    {
      "type": "column",
      "name": "Block content",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Column",
          "label": "Block title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
          "label": "Text with checkmarks"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Continue",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mosaic Blocks",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
