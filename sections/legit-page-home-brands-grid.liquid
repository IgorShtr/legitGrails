{% render 'section-legit-page-home-brands-grid-styles' %}
<div class="brand-grid-section brand-grid-section--{{ section.id }}" style="background-color:{{ section.settings.background_color }}"
     data-section-id="{{ section.id }}" data-section-type="logo-gallery">
    {% if section.settings.title != blank %}
        <p class="brand__heading section-header__title section-title font-title text-center" style="color: {{ section.settings.overlay_text }} ">{{ section.settings.title }}</p>
    {% endif %}
    <div class="brand-grid"
         style="justify-content: {{ section.settings.items_alignment }}">
        {% for block in section.blocks %}
            <div class="brand-grid__flex brand-grid__{{ section.blocks.size }}-column">
                <div class="brand-grid__text">
                    {% if block.settings.image != blank %}
                        {%- assign img_url = block.settings.image | img_url: 'master' %}
                        <img src="{{ img_url }}" loading="lazy" alt="{{ block.settings.check_label }}"
                             class="brand-grid__image" width="255" height="40" />
                    {% endif %}
                    {% if block.settings.cta_label != blank %}
                        <p class="h2 font-description text-title brand-grid__caption legit-check"
                           style="color: {{ section.settings.overlay_text }}">{{ block.settings.cta_label | escape }}</p>
                    {% endif %}
                    {% if block.settings.check_label != blank %}
                        <p class="text-white font-description">{{ block.settings.check_label }}</p>
                    {% endif %}
                </div>
                {% if block.settings.link != blank %}
                    <a href="{{ block.settings.link }}"
                       class="brand-grid__link font-title"></a>
                {% endif %}
            </div>

        {% endfor %}
    </div>
    {% if section.settings.button_text != blank %}
        <div class="gallery__view-all-wrap">
            <a href="{{ section.settings.section_link }}"
               class="main-btn font-title">
                {{ section.settings.button_text }}
            </a>
        </div>
    {% endif %}
</div>
{% if section.blocks.size == 0 %}
    {% include 'no-blocks' %}
{% endif %}

