{% render 'section-legit-product-search-styles' %}
<div class="product-search-section--{{ section.id }} product-search-section {% if section.settings.show_overlay %} product-search-section__overlay{% endif %}"
     style="background-image: url({{ section.settings.image | img_url: 'master' }})">
    <div class="product-search-section__inner">
        <div class="search-section-container">
            {% if section.settings.logo_image != blank %}
                <img class="search-logo" src="{{ section.settings.logo_image | img_url: '500x500' }}" loading="lazy" alt="{{ section.settings.title }}">
            {% endif %}
            <div class="products-search">
                {% if section.settings.title != blank %}
                    <div class="section-title text-center font-title">{{ section.settings.title }}</div>
                {% endif %}
                <label class="search-label font-title" for="product-search"><input type="text" id="product-search" class="input-product-search" name="q"
                                                   value="{{ search.terms | escape }}"
                                                   placeholder="Search Brand"/>
                </label>
                <div class="products-search_result font-description"></div>
            </div>
            {% if section.settings.url != blank %}
                <div class="products-search__link-wrap">
                    <a class="products-search__link font-title" href="{{ section.settings.url }}">{{ section.settings.link_text }}</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

