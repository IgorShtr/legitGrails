{% render 'section-product-form-block-inverse-styles' %}
<div class="block-inverse indent">
    <div class="block-inverse__title font-title">{{ section.settings.title }}</div>
    <div class="block-inverse__content">
        {%- for block in section.blocks -%}
            <div class="block-inverse_item">
                <div class="block-inverse__image">
                    <img src="{{ block.settings.image | img_url: 'master' }}" alt="form image"
                         width="50" loading="lazy">
                </div>
                <div class="block-inverse__text-column">
                    <div class="block-inverse__caption font-title"> {{ block.settings.title }}</div>
                    <div class="block-inverse__text-small font-description">
                        {{ block.settings.text }}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    {% if section.settings.description != blank %}
        <div class="block-inverse__description font-description">{{ section.settings.description }}</div>
    {% endif %}
</div>

{% schema %}
{
  "name": "Inverse block",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "<p>Description</p>",
      "label": "Section Description"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Block content",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
          "label": "Text with checkmarks"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inverse block",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}