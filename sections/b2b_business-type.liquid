<script>
  $(document).mouseup( function(e){
      var div = $( ".b2b_business-type_wrapp-select-wrapp" );
    	if ( !div.is(e.target)
		&& div.has(e.target).length === 0 ) {
		div.children('.b2b_business-type_wrapp-select-wrapp-options').hide();
	}
  });
  $('.b2b_business-type_wrapp-select-wrapp').on('click', function() {
    $('.b2b_business-type_wrapp-select-wrapp-options').toggleClass('active');
    $(this).toggleClass('active');
  });
  $('.b2b_business-type_wrapp-select-wrapp-option').on('click', function() {
    $('.b2b_business-type_wrapp-item').removeClass('active');
    var optionName = $(this).text();
    $('.b2b_business-type_wrapp-select-wrapp-main p').html(optionName);
    var NameBlock = $(this).attr('id');
    var TargetBlock = ".b2b_business-type_wrapp-item-" + NameBlock;
    $(TargetBlock).addClass('active');
  });
  
  $(document).ready(function () {
    
    $('.b2b_business-type_wrapp-btn').on('click', function() {
        $('.b2b_business-type_wrapp-btn').removeClass('active');
        $('.b2b_business-type_wrapp-item').removeClass('active');
        var NameBlock = $(this).attr('id');
        var TargetBlock = ".b2b_business-type_wrapp-item-" + NameBlock;
        $(TargetBlock).addClass('active');
        $(this).addClass('active');
      });
    
    $('.b2b_business-type_wrapp-select').on('change', function() {
        $('.b2b_business-type_wrapp-item').removeClass('active');
        var block = $(this).val();
        var chosenBlock = ".b2b_business-type_wrapp-item-" + block;
        $(chosenBlock).addClass('active');
      });
    
      $('.b2b_business-type_wrapp-select.option').on('click', function() {
        $('.b2b_business-type_wrapp-item').removeClass('active');
        if ($(this).text() === "Consignment Stores & Boutiques") {
          $('.b2b_business-type_wrapp-item-consignment-stores').addClass('active');
        } else if ($(this).text() === "Online Marketplaces (Seller-to-Buyer)") {
          $('.b2b_business-type_wrapp-item-online-marketplaces').addClass('active');
        } else if ($(this).text() === "Warehouse-Based Marketplaces") {
          $('.b2b_business-type_wrapp-item-warehouse').addClass('active');
        } else if ($(this).text() === "Pawn Shops") {
          $('.b2b_business-type_wrapp-item-pawn-shops').addClass('active');
        }
      });

    
  });
</script>
