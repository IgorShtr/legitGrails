  <script>
(function () {
  const BONUS_BY_TOPUP = {
    15: 0,
    50: 2,
    100: 5,
    150: 10,
    300: 40,
    500: 80,
    1000: 250,
    3000: 950,
    5000: 1600,
  };

  const BASE_PRICES = {
    "luxury":              { "12 hours": 15.00, "6 hours": 20.00, "2 hours": 25.00, "30 minutes": 35.00 },
    "hype":                { "12 hours": 4.00,  "6 hours": 5.00,  "2 hours": 6.00,  "30 minutes": 7.00  },
    "high-end watches":    { "12 hours": 50.00, "6 hours": 75.00, "2 hours": 90.00, "30 minutes": 105.00 },
    "chanel or hermes":    { "12 hours": 25.00, "6 hours": 35.00, "2 hours": 45.00, "30 minutes": 75.00 },
  };

  const $ = (sel, root = document) => root.querySelector(sel);
  const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

  const selectEl = $('.account-pricing_calculator-select select');
  const totalSpan = $('.account-pricing_calculator-select-result-span');
  const timeBtnsContainer = $('.account-pricing_calculator-times-btns');
  const timeBtns = $$('.account-pricing_calculator-times-btn', timeBtnsContainer);
  const cards = $$('.account-pricing_calculator-card');

  function normalizeLabel(str) {
    return (str || '')
      .toLowerCase()
      .normalize('NFD').replace(/\p{Diacritic}/gu, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function formatMoney(n) {
    return `$${n.toFixed(2)}`;
  }

  {% comment %} function formatThousands(num, thousandSep='.') {
    const s = Math.round(num).toString();
    return s.replace(/\B(?=(\d{3})+(?!\d))/g, thousandSep);
  } {% endcomment %}

  function getSelectedTopUp() {
    const rawVal = Number(selectEl.value || 0);
    const bonus = BONUS_BY_TOPUP[rawVal] || 0;
    const total = rawVal + bonus;
    return { rawVal, bonus, total };
  }

  function getActiveTimeLabel() {
    const active = $('.account-pricing_calculator-times-btn.active', timeBtnsContainer);
    return active ? active.textContent.trim() : null;
  }

  function setActiveTimeButton(btn) {
    timeBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  function updateTotalSpan() {
    const { total } = getSelectedTopUp();

    totalSpan.textContent = total;
  }

  function updateCards() {
    const { rawVal: started, total: overall } = getSelectedTopUp();
    const timeLabel = getActiveTimeLabel();
    if (!timeLabel) return;

    cards.forEach(card => {
      const titleEl = $('h3.h3-heading-pp', card);
      const mainPriceEl = $('.account-pricing_calculator-card-price-main', card);
      const secondaryPriceEl = $('.account-pricing_calculator-card-price-secondary', card);
      const countTextEl = card.querySelector('.body-text'); 

      if (!titleEl || !mainPriceEl || !secondaryPriceEl) return;


      const categoryKey = normalizeLabel(titleEl.textContent);


      let mappedKey = categoryKey;
      if (categoryKey.includes('high-end') && categoryKey.includes('watch')) mappedKey = 'high-end watches';
      if (categoryKey.includes('chanel') || categoryKey.includes('hermes')) mappedKey = 'chanel or hermes';

      const baseForTime = BASE_PRICES[mappedKey]?.[timeLabel];
      if (!baseForTime) {
        console.warn('No base price for:', { mappedKey, timeLabel });
        return;
      }


secondaryPriceEl.textContent = formatMoney(baseForTime);


const count = overall / baseForTime;
const countInt = Math.floor(count);


const main = started / (overall / baseForTime);

if (Math.abs(main - baseForTime) < 0.01) {
  mainPriceEl.textContent = formatMoney(baseForTime);
  secondaryPriceEl.textContent = '';
} else {
  mainPriceEl.textContent = formatMoney(main);
  secondaryPriceEl.textContent = formatMoney(baseForTime);
}

if (countTextEl) {
  const label = countInt === 1 ? 'authentication' : 'authentications';
  countTextEl.textContent = `${countInt} ${label} at`;
}
    });
  }

  function updateAll() {
    updateTotalSpan();
    updateCards();
  }
  selectEl.addEventListener('change', updateAll);

  timeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      setActiveTimeButton(btn);
      updateAll();
    });
  });
  document.addEventListener('DOMContentLoaded', updateAll);
  if (document.readyState !== 'loading') updateAll();
})();
</script>

