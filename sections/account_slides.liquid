<script>
  document.querySelectorAll('.account-slides_btn').forEach(function(button) {
    button.addEventListener('click', function() {
      document.querySelectorAll('.account-slides_btn').forEach(btn => {
        btn.classList.remove('active');
      });
      this.classList.add('active');
      const btnName = this.dataset.slide;
      const targetSlide = '.account-slides_slide-' + btnName;
      
      document.querySelectorAll('.account-slides_slide').forEach(slide => {
        slide.classList.remove('active');
      });
      const slide = document.querySelector(targetSlide);
      if (slide) {
        slide.classList.add('active');
      } else {
        console.warn(`Slide not found for selector: ${targetSlide}`);
      }
    });
  });
</script>

