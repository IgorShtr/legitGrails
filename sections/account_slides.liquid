<style>
  .account-slides_container {
    max-width: 1072px;
  }
  .account-slides_btns, .bs-slides_btns {
    border-radius: 6px;
    background: #F0F0F0;
    padding: 4px;
    width: max-content;
  }
  .account-slides_btn, .bs-slides_btn {
    padding: 10px 25px;
    border-radius: 5px;
    text-decoration: none;
    transition: .3s;
    line-height: 1;
  }
  .account-slides_btn.active, .bs-slides_btn.active {
    background: #FFF;
    box-shadow: 0px 3px 5px 0px rgba(0, 0, 0, 0.16);
    pointer-events: none;
  }
  .account-slides_slide, .bs-slides_slide {
    display: none;
  }
  .account-slides_slide.active, .bs-slides_slide.active {
    display: flex;
  }
  .account-slides_slide-offers {
    padding-left: 0;
    margin: 0;
  }
  .account-slides_slide-offers li svg {
    margin-top: 5px;
    width: 17px;
    height: auto;
  }
  .account-slides_slide-offers li {
    align-items: flex-start;
  }
  .account-slides_slide-offers li p {
    width: calc(100% - 27px);
  }
  .account-slides_slide-content {
    width: calc(100% - 422px);
  }
  img.account-slide_slide-image {
    width: 372px;
    height: auto;
  }
  @media(max-width: 1250px) {
    .account-slides_container {
      max-width: 950px;
    }
  }
  @media(max-width: 950px) {
    .account-slides_slide-content {
        width: 100%;
        text-align: center;
    }
    ul.account-slides_slide-offers {
        text-align: left;
        max-width: 700px;
        margin: auto;
    }
    .account-slides_slide .rebranding_btn {
      margin: auto;
    }
    img.account-slide_slide-image {
        width: 100%;
        height: auto;
        max-width: 400px;
        margin: auto;
    }
  }
  @media(max-width: 750px) {
    .account-slides_slide-offers li svg {
      margin-top: 4px;
      width: 14px;
    }
    .account-slides_slide-content {
      gap: 30px;
    }
    .account-slides_btns {
        border-radius: 6px;
        background: none;
        padding: 0;
        width: 100%;
        gap: 10px;
    }
    .account-slides_btn {
        border: 1px solid #EAEAEA;
        background: #FFF;
    }
    .account-slides_btn.active {
        background: #3C1F1B;
        box-shadow: none;
        pointer-events: none;
        color: #fff;
    }
  }

   .business-solutions_type-deal {
