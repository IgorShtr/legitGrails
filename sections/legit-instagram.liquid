{% render 'section-legit-instagram-styles' %}
<div class="section-instagram" data-section-id="{{ section.id }}">
    <div class="instagram-section-container">
        {%- unless section.settings.title == blank -%}
            <h2 class="section-title font-title">
                {{ section.settings.title | escape }}
            </h2>
        {%- endunless -%}
        {%- unless section.settings.description == blank -%}
            <div class="section-description font-description">
                {{ section.settings.description }}
            </div>
        {%- endunless -%}

        <div class="legit-instagram legit-instagram--{{ section.id }} "
             data-section-id="{{ section.id }}" data-section-type="gallery">
            {% for block in section.blocks %}
                {% if block.settings.image != blank %}
                    <a class="legit-instagram__link font-title" href="{{ block.settings.link }}">
                      <div class="legit-instagram__image lazyload" 
                                 data-bgset="{% include 'bgset', image: block.settings.image %}">
                            </div>
                    </a>
                {% endif %}
            {% endfor %}
        </div>

        {% if section.blocks.size == 0 %}
            {% include 'no-blocks' %}
        {% endif %}
    </div>
</div>

{% schema %}
{
  "name": {
    "en": "Legit Instagram"
  },
  "class": "section--instagram",
  "max_blocks": 9,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": {
        "en": "Heading"
      }
    },
    {
      "type": "text",
      "id": "description",
      "label": {
        "en": "Description"
      }
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": {
        "en": "Image"
      },
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": {
            "en": "Image"
          }
        },
        {
          "type": "url",
          "id": "link",
          "label": {
            "en": "Link"
          },
          "info": {
            "en": "Optional"
          }
        }
      ]
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Legit instagram"
      },
      "category": {
        "en": "Image"
      },
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
