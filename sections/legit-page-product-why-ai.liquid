<style>
.legit-image-icon__caption-small{text-transform:none;font-weight:700;text-align:center;font-size:18px;line-height:22px;color:#161616;margin-top:15px}@media (min-width:1024px){.legit-image-icon__caption-small{font-size:22px;margin-bottom:15px;text-transform:none}}.featured-collection{padding-bottom:0!important}
</style>
<div class="featured-collection collection-template" data-section-id="{{ section.id }}"
     data-section-type="collection-template">
    <div class="section-container">
        <div class="featured-collection__heading grid text-center">
            <div class="grid__item medium-up--ten-twelfths medium-up--push-one-twelfth">
                <p class="hero__overlay-title section-title font-title" data-animate>Why LegitGrails?</p>
            </div>
        </div>

        <div class="legit-image-icon legit-image-icon--{{ section.id }} legit-image-icon--{{ section.settings.section_height }}"
             data-section-id="{{ section.id }}" data-section-type="gallery">
                <div class="legit-image-icon__flex legit-image-icon__{{ section.blocks.size }}-column">
                        <div class="legit-image-icon__item legit-image-icon__item--{{ block.id }} lazyload" style="background-image: url('{{ "diamond.webp" | asset_url }}')">
                        </div>
                    <div class="legit-image-icon__text" data-animate>
                            <p class="h2 legit-image-icon__caption-small font-title">Hybrid Authentication</p>
                            <p>We combine human expertise and AI for authentication accuracy above 99.3% </p>
                    </div>
                </div>

          <div class="legit-image-icon__flex legit-image-icon__{{ section.blocks.size }}-column">
                        <div class="legit-image-icon__item legit-image-icon__item--{{ block.id }} lazyload" style="background-image: url('{{ "why-2.webp" | asset_url }}')">
                        </div>
                    <div class="legit-image-icon__text" data-animate>
                            <p class="h2 legit-image-icon__caption-small font-title">Money Back Guarantee</p>
                            <p>Get a full refund if there's an error in the authentication process</p>
                    </div>
                </div>

          <div class="legit-image-icon__flex legit-image-icon__{{ section.blocks.size }}-column">
                        <div class="legit-image-icon__item legit-image-icon__item--{{ block.id }} lazyload" style="background-image: url('{{ "chat.webp" | asset_url }}')">
                        </div>
                    <div class="legit-image-icon__text" data-animate>
                            <p class="h2 legit-image-icon__caption-small font-title">Easy Communication</p>
                            <p>Live chat or email our authenticators at any point, available 24/7</p>
                    </div>
                </div>

          <div class="legit-image-icon__flex legit-image-icon__{{ section.blocks.size }}-column">
                        <div class="legit-image-icon__item legit-image-icon__item--{{ block.id }} lazyload" style="background-image: url('{{ "benefit-4.webp" | asset_url }}')">
                        </div>
                    <div class="legit-image-icon__text" data-animate>
                            <p class="h2 legit-image-icon__caption-small font-title">Authenticity Certificate</p>
                            <p>Get quick and reliable results & an official authenticity certificate</p>
                    </div>
                </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": {
    "en": "Legit page product why ai"
  },
  "class": "index-section--services",
  "max_blocks": 4,
  "settings": [
    {
      "type": "select",
      "id": "section_height",
      "label": {
        "en": "Section height"
      },
      "default": "medium",
      "options": [
        {
          "label": {
            "en": "Extra Small"
          },
          "value": "x-small"
        },
        {
          "label": {
            "en": "Small"
          },
          "value": "small"
        },
        {
          "label": {
            "en": "Medium"
          },
          "value": "medium"
        },
        {
          "label": {
            "en": "Large"
          },
          "value": "large"
        },
        {
          "label": {
            "en": "Extra Large"
          },
          "value": "x-large"
        }
      ]
    },
    {
      "type": "text",
      "id": "title",
      "label": {
        "en": "Heading"
      },
      "default": {
        "en": "Legit services"
      }
    },
    {
      "type": "text",
      "id": "description",
      "label": {
        "en": "Description"
      }
    },
    {
      "type": "text",
      "id": "button_label",
      "label": {
        "en": "Button label"
      }
    },
    {
      "type": "url",
      "id": "button_link",
      "label": {
        "en": "Button link"
      }
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": {
        "en": "Image"
      },
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": {
            "en": "Image"
          }
        },
        {
          "type": "header",
          "content": {
            "en": "Text"
          }
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": {
            "en": "Caption"
          },
          "default": {
            "en": "Talk about your brand"
          }
        },
        {
          "type": "richtext",
          "id": "block_description",
          "label": {
            "en": "Description"
          },
          "default": {
            "en": "<p>Describe your brand</p>"
          }
        },
        {
          "type": "url",
          "id": "link",
          "label": {
            "en": "Link"
          },
          "info": {
            "en": "Optional"
          }
        }
      ]
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Legit page product why ai"
      },
      "category": {
        "en": "Image"
      },
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
