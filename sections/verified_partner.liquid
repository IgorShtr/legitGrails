{% assign array_of_image_objects = page.metafields.custom.verified_partner_clients_logos.value %}

<style>
  .verified-partner {
    padding-top: 50px;
  }
  .verified-partners_card, .verified-partner_cards-details {
    border-radius: 11px;
    border: 1px solid #D4D4D4;
    padding: 30px 20px;
  }
  .verified-partners_card-image-wrapp {
    height: 200px;
  }
  .verified-partners_card-image {
height: auto;
max-height: 100%;
width: auto;
  }
  .verified-partners_card-description {
    overflow: hidden;
    text-overflow: ellipsis;
    -webkit-line-clamp: 4;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
  }
.verified-partners_card-location p {
max-width: calc(100% - 100px);
text-align: center;
}
  .verified-partners_card-location svg {
    margin-top: -1px;
  }
  .verified-partner_cards {
    width: 450px;
    height: max-content;
  }
  .verified-partner_text {
    width: calc(100% - 500px);
    height: max-content;
  }
  .verified-partner_cards-details ul {
    padding-left: 40px;
    margin-top: 5px;
    margin-bottom: 30px;
  }
  .verified-partner_cards-details ul:last-child {
    margin-bottom: 0;
  }
  .verified-partner_text-item {
    color: #3C1F1B;
  }
  .verified-partner_text-item p {
    margin-bottom: 15px;
  }
  .verified-partner_text-item p:last-child {
    margin-bottom: 0;
  }
  .verified-partner_text-item-images img {
    height: 30px;
  }
  .verified-partner_map {
    height: 500px;
    width: 100%;
    overflow: hidden;
    border-radius: 10px;
  }
  .verified-partner_map iframe {
    margin-top: -71px;
    width: calc(100% + 4px);
margin-left: -2px;
margin-right: -2px;
margin-bottom: -2px;
  }
  @media(max-width: 1250px) {
    .verified-partner_cards {
      width: 350px;
    }
    .verified-partner_text {
      width: calc(100% - 400px);
    }
  }
  @media(max-width: 950px) {
    .verified-partner_cards, .verified-partner_text {
      width: 100%;
    }
  }
  @media(max-width: 750px) {
    .verified-partners_card-image-wrapp {
      height: 130px;
    }
  }
</style>

<div class="rebranding_container">
  <div class="w-100 block-flex-wrap block-gap-50">
    <div class="verified-partner_cards block-flex-wrap block-gap-20">
      <div class="verified-partners_card w-100 block-flex-wrap block-gap-30 block-flex-center-center tac">
           <div class="verified-partners_card-image-wrapp block-flex-wrap block-flex-center-center">
             <img class="verified-partners_card-image" src="{{ page.metafields.custom.verified_partner_logo.value | image_url }}">
           </div>
           <div class="w-100 block-flex-wrap block-gap-20 block-flex-center-center">
               <h3 class="h3-heading-pp w-100 tac">{{ page.title }}</h3>
               <p class="body-text w-100">LegitGrails client since: {{ page.metafields.custom.verified_partner_verified_since }}</p>
               <div class="w-100 verified-partners_card-location block-flex-wrap block-flex-start-center block-gap-10">
                  <svg width="18" height="24" viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8.99998 0C6.61401 0.00317495 4.32668 0.952405 2.63954 2.63954C0.952404 4.32668 0.00317495 6.61402 0 8.99999C0 15.4612 8.38498 23.5537 8.74123 23.895C8.81053 23.9623 8.90335 24 8.99998 24C9.09661 24 9.18944 23.9623 9.25873 23.895C9.61498 23.5537 18 15.4612 18 8.99999C17.9968 6.61402 17.0476 4.32668 15.3604 2.63954C13.6733 0.952405 11.3859 0.00317495 8.99998 0ZM8.99998 13.125C8.18413 13.125 7.38661 12.8831 6.70826 12.4298C6.02991 11.9765 5.5012 11.3323 5.18899 10.5786C4.87678 9.82481 4.79509 8.99541 4.95425 8.19524C5.11341 7.39507 5.50628 6.66007 6.08317 6.08318C6.66006 5.50629 7.39506 5.11342 8.19523 4.95426C8.9954 4.79509 9.8248 4.87678 10.5785 5.18899C11.3323 5.5012 11.9765 6.02991 12.4298 6.70827C12.883 7.38662 13.125 8.18414 13.125 8.99999C13.1243 10.0938 12.6895 11.1426 11.916 11.916C11.1426 12.6895 10.0938 13.1243 8.99998 13.125Z" fill="#3C1F1B"/>
                  </svg>
                  <p class="body-text">{{ page.metafields.custom.verified_partner_location }}</p>
               </div>
             </div>
            <div class="block-flex-wrap block-gap-10 w-100">
               <a target="_blank" href="{{ page.metafields.custom.verified_partner_website }}" class="rebranding_btn w-100">Visit a website</a>
            </div>
         </div>
      <div class="verified-partner_cards-details body-text w-100">
        {{ page.metafields.custom.verified_partner_left_column | metafield_tag }}
      </div>
    </div>
    <div class="verified-partner_text block-flex-wrap block-gap-50">
      <div class="verified-partner_text-item block-flex-wrap block-gap-20">
        <h3 class="h3-heading-pp w-100">About {{ page.title }}</h3>
        <div class="body-text w-100">
          {{ page.content }}
        </div>
      </div>
      {% if array_of_image_objects %}
        <div class="verified-partner_text-item block-flex-wrap block-gap-20">
          <h3 class="h3-heading-pp w-100">Clients</h3>
          <div class="verified-partner_text-item-images block-flex-wrap block-gap-50">
            {% for image_object in array_of_image_objects %}
                <img src="{{ image_object | image_url }}" loading="lazy" alt="Verified partner clients logo" >
            {% endfor %}
          </div>
        </div>
      {% endif %}
      <div class="verified-partner_map">
        {{ page.metafields.custom.verified_partner_map }}
      </div>
      
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Verified partner",
    "class": "verified-partner rebranding-section-bottom",
    "settings": []
  }
{% endschema %}