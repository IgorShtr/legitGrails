<script>
  (function () {
    const btnWrap = document.querySelector('.resalex_pricing-btns');
    const btns = [...btnWrap.querySelectorAll('.resalex_pricing-btn')];
    const items = [...document.querySelectorAll('.resalex_pricing-item')];

    function activate(key) {
      // buttons
      btns.forEach(b => {
        const on = b.dataset.slide === key;
        b.classList.toggle('active', on);
        b.setAttribute('aria-pressed', on);
      });
      // cards
      items.forEach(card => {
        const match = card.classList.contains(`resalex_pricing-item-${key}`);
        card.classList.toggle('active', match);
        card.hidden = !match; // also good for screen readers
      });
    }

    // click to switch
    btnWrap.addEventListener('click', (e) => {
      const btn = e.target.closest('.resalex_pricing-btn');
      if (!btn) return;
      e.preventDefault();
      activate(btn.dataset.slide);
    });

    // init from any pre-marked .active button or default to first
    const initial = btns.find(b => b.classList.contains('active'))?.dataset.slide
                 || btns[0]?.dataset.slide;
    if (initial) activate(initial);
  })();
</script>

