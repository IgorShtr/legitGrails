<div class="featured-blog legit-featured-blog featured-blog--{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="featured-blog">
    <div class="section-container">
        {% if section.settings.title != blank %}
            <h3 class="featured-blog__heading section-header__title section-title  text-center" data-animate>{{ section.settings.title | escape }}</h3>
        {% endif %}
        {%- assign blog = linklists.blog-links.links -%}
        {%- assign mobileColumns = 1 -%}

        {% unless blog.size == 1 %}
            {% case section.settings.post_limit %}
                {% when 6 %}
                    {%- assign desktopColumns = 3 -%}
                  {%- assign width = 'medium-up--one-third' -%}
                {% when 5 %}
                    {%- assign desktopColumns = 3 -%}
                {%- assign width = 'medium-up--one-third' -%}
                {% when 4 %}
                    {%- assign desktopColumns = 3 -%}
                {%- assign width = 'medium-up--one-third' -%}
                {% when 3 %}
                    {%- assign desktopColumns = 3 -%}
                    {%- assign width = 'medium-up--one-third' -%}
                {% when 2 %}
                    {%- assign desktopColumns = 2 -%}
                    {%- assign width = 'medium-up--one-half' -%}
                {% when 1 %}
                    {%- assign desktopColumns = 1 -%}
                    {%- assign width = 'one-whole' -%}
                {% else %}
                    {%- assign desktopColumns = 3 -%}
                    {%- assign width = 'medium-up--one-third' -%}
            {% endcase %}
        {% endunless %}
        {% capture emptyBlog %}
            <div class="card-list grid" data-desktop-columns="{{ desktopColumns }}" data-mobile-columns="{{ mobileColumns }}">
                <div class="card-list__column grid__item {{ width }}{% if mobileColumns == 2 %} small--one-half{% endif %}">
                    {% for i in (1..section.settings.post_limit)  %}
                        <div class="card critical-clear" data-animate>
                            <a class="card__wrapper card--article">
                            {% if section.settings.blog_show_image %}
                            {% if section.settings.post_limit == 1 %}
                            <div class="medium-up--one-half card-list__column--half-left">
                                {% endif %}
                            <div class="card__image-wrapper">
                                {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                                {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                            </div>
                            {% if section.settings.post_limit == 1 %}
                                </div>
                            {% endif %}
                            {% if blog.size == 1 or section.settings.post_limit == 1 %}
                                <div class="medium-up--one-half card-list__column--half-right">
                                    {% endif %}
                                    {% endif %}
                                    <div class="card__info">
                                        <h4 class="card__name">{{ 'homepage.onboarding.blog_title' | t }}</h4>
                                        {% if section.settings.blog_show_excerpt %}
                                            <div class="card__excerpt rte">
                                                {{ 'homepage.onboarding.blog_excerpt' | t }}
                                            </div>
                                        {% endif %}
                                        <span class="card__read-more">
                    {{ 'blogs.article.read_more' | t }}
                                            {% include 'icon-arrow-right' %}
                  </span>
                                    </div>
                                    {% if section.settings.blog_show_image %}
                                    {% if blog.size == 1 or section.settings.post_limit == 1 %}
                                </div>
                                {% endif %}
                                {% endif %}
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endcapture %}

        {% unless blog.size == 0 %}
            <div class="card-list grid card-list-carousel" data-desktop-columns="{{ desktopColumns }}" data-mobile-columns="3" data-grid-style="{{ section.settings.grid_style }}">
                <div class="card-list__column grid__item {{ width }}{% if mobileColumns == 2 %} small--one-half{% endif %}">
                    {% for link in blog limit: section.settings.post_limit %}
                        {% assign article_link = link.url | remove: "/blogs/" %}
                        {% assign article =  articles[article_link] %}
                        {% include 'legit-article-card', article: article, grid_style: section.settings.grid_style %}
                    {% endfor %}
                </div>
            </div>
        {% else %}
            {{ emptyBlog }}
        {% endunless %}

        {% if blog == empty %}
            {{ emptyBlog }}
        {% endif %}

        {% if section.settings.show_view_all %}
            <div class="featured-blog__view-all-wrap">
                <a href="https://legitgrails.com/pages/guides" class="main-btn{% if section.settings.use_second_button %} btn--secondary{% endif %}">
                    {{ 'collections.general.view_all' | t }}
                </a>
            </div>
        {% endif %}

    </div>
</div>
{% schema %}
{
"name": {
"en": "Legit featured blog posts"
},
"class": "index-section",
"settings": [
{
"type": "text",
"id": "title",
"label": {
"en": "Heading"
},
"default": {
"en": "Blog"
}
},
{
"type": "range",
"id": "post_limit",
"label": {
"en": "Posts"
},
"min": 1,
"max": 6,
"step": 1,
"default": 6
},
{
"type": "checkbox",
"id": "blog_show_date",
"label": {
"en": "Show date"
},
"default": true
},
{
"type": "checkbox",
"id": "blog_show_author",
"label": {
"en": "Show author"
},
"default": false
},
{
"type": "checkbox",
"id": "blog_show_image",
"label": {
"en": "Show cover image"
},
"default": false
},
{
"type": "checkbox",
"id": "blog_show_excerpt",
"label": {
"en": "Show excerpt"
},
"default": true
},
{
"type": "checkbox",
"id": "show_view_all",
"label": {
"en": "Show 'View all' button"
},
"default": false
},
{
"type": "checkbox",
"id": "link_target",
"label": {
"en": "Open links in a new window"
},
"default": true
},
{
"type": "url",
"id": "button_link",
"label": {
"en": "Button link"
}
}
],
"presets": [
{
"name": {
"en": "Legit featured blogs"
}
}
]
}
{% endschema %}

