<script>
document.querySelectorAll('.accountCalculatorBtn').forEach(function(button) {
  button.addEventListener('click', function () {

    document.querySelectorAll(`.accountCalculatorBtn[data-type="${this.dataset.type}"]`).forEach(btn => {
      btn.classList.remove('active');
    });


    this.classList.add('active');


    if (this.dataset.type === 'category') {
      changeCategoryText();
      changePricingText();
    } else if (this.dataset.type === 'pricing') {
      changePricingText();
    } else {
      console.warn(`Unrecognized data type: ${this.dataset.type}`);
    }
  });
});

const categoryTexts = {
  Luxury: "Brands like Gucci, Louis Vuitton, and more",
  Hype: "Brands like Nike, Adidas, and more"
};

const pricingBonusTexts = {
  "300": "$300 gives you 300 credits + 40 bonus credits",
  "1000": "$1,000 gives you 1,000 credits + 250 bonus credits",
  "5000": "$5,000 gives you 5,000 credits + 1,660 bonus credits"
};

const pricingData = {
  Luxury: {
    "5": { main: 15.00, secondary: '' },
    "25": { main: 13.24, secondary: 15.00 },
    "100": { main: 12.00, secondary: 15.00 },
    "500": { main: 11.36, secondary: 15.00 }
  },
  Hype: {
    "5": { main: 4.00, secondary: '' },
    "300": { main: 3.53, secondary: 4.00 },
    "500": { main: 3.20, secondary: 4.00 },
    "1700": { main: 3.03, secondary: 4.00 }
  }
};

function getActiveButtonText(type) {
  const btn = document.querySelector(`.accountCalculatorBtn.active[data-type="${type}"]`);
  if (!btn) {
    console.warn(`No active button found for type "${type}".`);
    return null;
  }


  if (type === 'pricing') {
    return btn.dataset.pricing;
  }

  return btn.textContent.trim();
}

function updateTextContent(selector, text, useHTML = false) {
  const element = document.querySelector(selector);
  if (!element) {
    console.warn(`Target element not found for selector: ${selector}`);
    return;
  }
  if (useHTML) {
    element.innerHTML = text ?? '';
  } else {
    element.textContent = text ?? '';
  }
}

function changeCategoryText() {
  const category = getActiveButtonText('category');
  if (!category) return;

  const text = categoryTexts[category];
  updateTextContent('p[data-type="categoryText"]', text);
}

function changePricingText() {
  const category = getActiveButtonText('category');
  const pricing = getActiveButtonText('pricing');
  if (!category || !pricing) return;

  const priceInfo = pricingData[category]?.[pricing];
  const bonusText = pricingBonusTexts[pricing];

  if (priceInfo) {
    updateTextContent('p.main-price', `$${priceInfo.main.toFixed(2)}`);

    const secondaryEl = document.querySelector('p.secondary-price');
    if (!secondaryEl) return;

    const hasSecondaryNumber = typeof priceInfo.secondary === 'number' && !isNaN(priceInfo.secondary);
    const isSame = hasSecondaryNumber && Math.abs(priceInfo.secondary - priceInfo.main) < 0.01;

    if (hasSecondaryNumber && !isSame) {
      secondaryEl.textContent = `$${priceInfo.secondary.toFixed(2)}`;
      secondaryEl.style.display = '';     // show
    } else {
      secondaryEl.textContent = '';       // clear any old text
      secondaryEl.style.display = 'none'; // hide
    }
  }

  updateTextContent('span[data-type="pricingText"]', bonusText || '');
}

const pricingOptions = {
    Luxury: ['5', '25', '100', '500'],
    Hype: ['5', '300', '500', '1700'],
  };

  function filterPricingButtons() {
    const category = getActiveButtonText('category'); 
    if (!category) return;

    const allowed = pricingOptions[category] || [];
    const pricingBtns = Array.from(document.querySelectorAll('.accountCalculatorBtn[data-type="pricing"]'));


    pricingBtns.forEach(btn => {
      const val = btn.dataset.pricing;
      btn.style.display = allowed.includes(val) ? '' : 'none';
    });


    let active = document.querySelector('.accountCalculatorBtn.active[data-type="pricing"]');
    const activeVal = active?.dataset.pricing;

    if (!active || !allowed.includes(activeVal)) {

      pricingBtns.forEach(b => b.classList.remove('active'));

      const firstAllowed = pricingBtns.find(b => allowed.includes(b.dataset.pricing));
      if (firstAllowed) firstAllowed.classList.add('active');
    }


    changePricingText();
  }

  document.addEventListener('DOMContentLoaded', function () {
    filterPricingButtons();
  });

  document.querySelectorAll('.accountCalculatorBtn[data-type="category"]').forEach(btn => {
    btn.addEventListener('click', filterPricingButtons);
  });
</script>

