<style>
  .card-with-shadow {
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #EAEAEA;
    background: #FFF;
    box-shadow: 0px 52px 15px 0px rgba(108, 77, 72, 0.00), 0px 33px 13px 0px rgba(108, 77, 72, 0.01), 0px 19px 11px 0px rgba(108, 77, 72, 0.03), 0px 8px 8px 0px rgba(108, 77, 72, 0.04), 0px 2px 5px 0px rgba(108, 77, 72, 0.05);
  }
  .account-calculator_item {
    width: 410px;
    height: 348px;
  }
  .account-calculator_item-product {
    width: calc(100% - 850px);
    border: 1px solid #F6ECD5;
    background: #FFFCF5;
    height: max-content;
  }
  .account-calculator_item-offer svg {
    width: 47px;
    height: 47px;
  }
  .account-calculator_item-offer p {
    width: calc(100% - 62px);
  }
  .account-calculator_item-prices {
    position: relative;
  }
  .secondary-price {
    font-size: 26px;
    letter-spacing: -1.04px;
    opacity: 0.7;
    position: absolute;
    top: 50%;
    margin-top: -14px;
    left: calc(100% + 10px);
    text-decoration: line-through;
}
  .account-calculator_item-prices-wrapp {
  position: relative;
}
  @media(max-width: 1450px) {
    .account-calculator_item-product {
      width: 835px;
      order: 1;
    }
    .account-calculator_item-offers {
      order: 2;
    }
    .account-calculator_item-deal {
      order: 3;
    }
  }
  @media(max-width: 950px) {
    .account-calculator_item {
      width: calc(50% - 7.5px);
    }
    .account-calculator_item-product {
      width: 100%;
    }
  }
  @media(max-width: 750px) {
    .secondary-price {
    font-size: 20px;
    letter-spacing: -0.8px;
    }
    .account-calculator_item-deal {
      display: none;
    }
    .account-calculator_item {
      gap: 30px;
      width: 100%;
      height: max-content;
    }
    .account-calculator_item-product-btns {
      gap: 30px;
    }
    .account-calculator_item-offer {
        width: 100%;
        max-width: 343px;
        margin: 0 auto;
        height: max-content;
    }
    .account-calculator_item-offer svg {
        width: 40px;
        height: auto;
    }
    .account-calculator_item-offer p {
        width: calc(100% - 55px);
    }
  }
</style>

