          <img class="hype_coverage-item-image" src="{{ 'hype_authenticate-2.png' | asset_url }}">
        </div>
        <p class="hype_coverage-item-title section-desc-style">Clothing</p>
      </div>
      <div class="hype_coverage-item hype_coverage-item-3">
        <div class="hype_coverage-item-image-wrapp">
          <img class="hype_coverage-item-image" src="{{ 'hype_authenticate-3.png' | asset_url }}">
        </div>
        <p class="hype_coverage-item-title section-desc-style">Shoes</p>
      </div>
      <div class="hype_coverage-item hype_coverage-item-4">
        <div class="hype_coverage-item-image-wrapp">
          <img class="hype_coverage-item-image" src="{{ 'hype_authenticate-4.png' | asset_url }}">
        </div>
        <p class="hype_coverage-item-title section-desc-style">Jewelry</p>
      </div>
      <div class="hype_coverage-item hype_coverage-item-5">
        <div class="hype_coverage-item-image-wrapp">
