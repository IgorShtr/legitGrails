          <img class="hype_coverage-item-image" src="{{ 'hype_authenticate-1.png' | asset_url }}">
        </div>
        <p class="hype_coverage-item-title section-desc-style">Handbags</p>
      </div>
      <div class="hype_coverage-item hype_coverage-item-2">
