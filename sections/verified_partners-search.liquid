    display: flex;
  }
  .verified-partners_card {
    border-radius: 11px;
    border: 1px solid #D4D4D4;
    padding: 30px 20px;
    display: none;
    height: 556px;
  }
  .verified-partners_card.active {
    display: flex;
  }
  .verified-partners_card-image-wrapp {
    height: 200px;
  }
  .verified-partners_card-image {
    height: auto;
    max-height: 100%;
    width: auto;
  }
  .verified-partners_card {
    width: calc(33.33334% - 13.33334px);
  }
  .verified-partners_search-wrapp {
    width: calc(100% - 508px);
    padding: 6px 6px 6px 20px;
    border-radius: 12px;
    border: 1px solid #3C1F1B;
  }
