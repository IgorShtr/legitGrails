<script>  
    (function () {
        const searchField = document.getElementById('search-partners-input')
        const brands = Array.from(document.getElementsByClassName('verified-partners_card'))
        let chosenFilterTitle = document.querySelector('.verified-partners_country-items-wrapp-main-title')
        const filterButtonsWrapp = document.querySelector('.verified-partners_country-items-wrapp')
        const filterButtons = document.querySelector('.verified-partners_country-items-wrapp-options')
        const brandContainer = document.querySelector('.verified-partners_cards')
        const typeOfContentBtns = document.querySelector('.verified-partners_open-btns')
        const typeOfContentBtn = document.querySelector('.verified-partners_open-btn')

        let type = 'all'
        let searchString = ''

        function searchBrand(type, string) {
            document.querySelector('.verified-partners_cards').classList.add('searching')
            console.log(brandContainer)
            brands.forEach((block) => {
                if (string.length === 0) {
                    if (type === block.dataset.type || type === 'all') {
                        block.classList.add('active')
                    } else {
                        block.classList.remove('active')
                    }
                } else if (string.length > 0) {
                    if ((type === block.dataset.type || type === 'all') && (block.dataset.name.includes(string.toLowerCase()))) {
                        block.classList.add('active')
                    } else {
                        block.classList.remove('active')
                    }
                } else {
                    block.classList.remove('active')
                }
            })
            setTimeout(()=> {
                document.querySelector('.verified-partners_cards').classList.remove('searching')
            }, 400)
        }

        function setActiveBtn(id) {
            let activeID = document.querySelector('.verified-partners_country-items-wrapp-options').querySelector('.active')
            activeID.classList.remove('active')
            document.getElementById(id).classList.add('active')
        }

        Array.from(filterButtons.children).forEach((a) => {
          a.addEventListener('click', () => {
                if (a.id === 'all') {
                  type = 'all';
                } else {
                  type = a.innerText.toLowerCase().replace(/\s+/g, '-');
                }
                searchBrand(type, searchString);
                let filterTitle = a.innerText;
                chosenFilterTitle.innerHTML = filterTitle;
            })
        })

        filterButtonsWrapp.addEventListener("click", (event) => {
          filterButtonsWrapp.classList.toggle('active');
        });

        document.addEventListener('click', event => {
          if (!filterButtonsWrapp.contains(event.target)) filterButtonsWrapp.classList.remove('active');;
        });

        searchField.addEventListener('input', (event) => {
            searchString = event.target.value
            searchBrand(type, event.target.value)
        })

        searchField.addEventListener('click', () => {
            searchField.parentElement.classList.add('focused')
        })

        searchField.addEventListener('blur', () => {
            searchField.parentElement.classList.remove('focused')
        })

        Array.from(typeOfContentBtns.children).forEach((a) => {
          a.addEventListener('click', () => {
            const currentActiveBtn = typeOfContentBtns.querySelector('.active');
            if (currentActiveBtn) {
              currentActiveBtn.classList.remove('active');
            }

            if (a.classList.contains('verified-partners_open-btn-map')) {
              document.querySelector('.verified-partners_filters').classList.add('maps-filters');
            } else {
              document.querySelector('.verified-partners_filters').classList.remove('maps-filters');
            }
        
            a.classList.add('active');
        
            const currentActiveContent = document.querySelector('.verified-partners.active');
            if (currentActiveContent) {
              currentActiveContent.classList.remove('active');
            }
        
            const typeOfContent = a.id;
            const displayedContentId = '.verified-partners_' + typeOfContent;
            document.querySelector(displayedContentId).classList.add('active');
          });
        });

    })();
</script>
