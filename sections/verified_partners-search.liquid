  .verified-partners_country-items-wrapp-main svg {
      width: 26px;
      margin-right: 1px;
      min-width: 26px;
      height: auto;
  }
  .verified-partners_country-items-wrapp-option {
      padding: 20px;
      text-decoration: none;
