    display: flex;
  }
  .verified-partners_country-items-wrapp.active svg {
    transform: rotate(180deg)
  }
.verified-partners_card-location p {
max-width: calc(100% - 100px);
text-align: center;
}
  .verified-partners_card-location svg {
    margin-top: -1px;
  }
    a.verified-partners_card-btn-website {
    min-width: auto;
    width: 84px;
    padding: 12px 28px;
    height: 50px;
  }
  .verified-partners_card-btns {
  margin-top: auto;
}
  a.verified-partners_card-btn-more {
    width: calc(100% - 94px);
    min-width: auto;
  }
  a.verified-partners_card-btn-website svg {
    height: 22px;
  }
  .verified-partners_map {
    height: 800px;
    overflow: hidden;
    border-radius: 11px;
  }
  .verified-partners_map iframe {
    margin-top: -62px;
    width: calc(100% + 4px);
    margin-left: -2px;
    margin-right: -2px;
    margin-bottom: -4px;
  }
  @media(max-width: 1450px) {
  .verified-partners_card {
  min-height: 582px;
}
}
  @media(max-width: 1250px) {
    .verified-partners_search-wrapp {
      width: 100%;
      order: 4;
    }
    .verified-partners_filters.maps-filters .verified-partners_search-wrapp {
      width: calc(100% - 148px);
      order: 1;
    }
    .verified-partners_filters.maps-filters .verified-partners_open-btns {
      order: 2;
    }
    .verified-partners_country-items-wrapp {
      width: calc(100% - 180px);
    }
    .verified-partners_card {
      width: calc(50% - 10px);
      min-height: 556px;
    }
  }
  @media(max-width: 750px) {
    .verified-partners_card {
      width: 100%;
      height: max-content;
      min-height: max-content;
    }
    span.verified-partners_search-icon {
      width: 52px;
      height: 44px;
    }
    #search-partners-input {
      height: 44px;
      width: calc(100% - 67px);
    }
    .verified-partners_open-btn {
      height: 58px;
      width: 64px;
    }
    .verified-partners_country-items-wrapp {
      height: 58px;
      width: calc(100% - 148px);
    }
    .verified-partners_country-items-wrapp-main svg {
      width: 22px;
      min-width: 22px;
    }
    .verified-partners_open-btn svg {
      width: 20px;
    }
    .verified-partners_card-image-wrapp {
      height: 130px;
    }
    a.verified-partners_card-btn-website {
      width: 80px;
    }
    a.verified-partners_card-btn-more {
      width: calc(100% - 90px);
    }
    .verified-partners_filters.maps-filters .verified-partners_search-wrapp {
      width: calc(100% - 148px);
    }
  }
</style>

