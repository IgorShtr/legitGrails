    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
  }
  .verified-partners_country-items-wrapp {
    width: 312px;
    position: relative;
    height: 66px;
    border-radius: 12px;
    border: 1px solid #3C1F1B;
    display: flex;
    align-items: center;
    padding: 6px 20px;
  }
