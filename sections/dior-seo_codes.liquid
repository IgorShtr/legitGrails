<style>
    .dior-seo_codes-desc {
        width: calc(50% - 15px);
    }
    .dior-seo_codes-table {
        border-radius: 8px;
        border: 1px solid rgba(60, 31, 27, 0.20);   
        padding: 20px 30px;
        gap: 37px;
        width: calc(50% - 15px);
    }
    .dior-seo_codes-table svg {
        width: 100%;
        height: auto;
    }
    .dior-seo_codes-desc p.caption {
        font-weight: 600;
    }
    @media(max-width: 1250px) {
        .dior-seo_codes-desc, .dior-seo_codes-table {
            width: 100%;
        }
        .dior-seo_codes-desc {
            justify-content: center;
            text-align: center;
        }
        .dior-seo_codes-desc p.caption {
            width: 100%;
        }
    }
    @media(max-width: 750px) {
    .dior-seo_codes-table {
    padding: 15px 20px;
}
}
