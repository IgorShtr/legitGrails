          </svg>
        </a>
      </div>
      <a href="https://legitgrails.com/" class="header_logo">
        <svg class="header_logo-image" width="169" height="28" viewBox="0 0 572 94" fill="none" xmlns="http://www.w3.org/2000/svg">
