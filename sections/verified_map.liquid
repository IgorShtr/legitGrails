<style>
  .verified-map {
    height: 676px;
    width: 100%;
    overflow: hidden;
    position: relative;
  }
  iframe {
    margin-top: -71px;
    width: calc(100% + 4px);
    margin-left: -2px;
    margin-right: -2px;
    margin-bottom: -4px;
  }
  @media(max-width: 750px) {
    .verified-map {
      height: 500px;
    }
    .verified-map iframe {
      height: 571px;
    }
  }
  .map-container iframe {
    pointer-events: none;
  }
  .map-container:hover iframe {
    pointer-events: auto;
  }
</style>

<iframe src="https://www.google.com/maps/d/u/0/embed?mid=1M-S71b9CSkodUkFjCCvMxv_AInWFFzw&ehbc=FFFFFF&z=4&noprof=1" width="100%" height="747px"></iframe>
{% schema %}
  {
    "name": "Verified Map",
    "class": "verified-map",
    "settings": []
  }
{% endschema %}