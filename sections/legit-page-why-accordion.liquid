    {% schema %}
    {
      "name": "Accordion blocks",
      "class": "section",
      "tag": "section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "default": "<p>Description</p>",
          "label": "Section Description"
        }
      ],
      "blocks": [
        {
          "type": "column",
          "name": "Block content",
          "settings": [
            {
              "type": "text",
              "id": "title",
              "default": "Column",
              "label": "Block title"
            },
            {
              "type": "richtext",
              "id": "text",
              "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
              "label": "Text"
            }
          ]
        }
      ],
      "presets": [
        {
          "name": "Accordion Blocks",
          "blocks": [
            {
              "type": "column"
            },
            {
              "type": "column"
            }
          ]
        }
      ]
    }
    {% endschema %}
