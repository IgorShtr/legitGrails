{% render 'section-legit-page-why-accordion-styles' %}
<div class="section-{{ section.id }} section-accordion">
    <div class="accordion-section">
        {%- unless section.settings.title == blank -%}
            <h2 class="section-title text-center font-title">
                {{ section.settings.title | escape }}
            </h2>
        {%- endunless -%}
        {%- unless section.settings.description == blank -%}
            <div class="section-description text-center font-description">
                {{ section.settings.description }}
            </div>
        {%- endunless -%}
    </div>
    <div class="section-blocks" id="section-blocks--{{ section.id }}">
        {%- for block in section.blocks -%}
            <div id="card-{{ forloop.index }}" class="accordion-card">
                {%- if block.settings.title != blank -%}
                    <div class="accordion-card__heading">
                        <div class="accordion-card__title font-title">{{ block.settings.title | escape }}</div>
                        <div class="accordion-card__arrow"></div>
                    </div>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                    <div class="accordion-card__content font-description" style="height: 0px">
                        <div>
                            {{ block.settings.text }}
                        </div>
                    </div>
                {%- endif -%}
            </div>
        {%- endfor -%}
    </div>
