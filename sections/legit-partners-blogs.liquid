<style>
.template-partners .card__image {
    border-radius: 0;
}
  .template-partners .blog-info__description {
    display: block;
}
  .template-partners .card__image-wrapper {
    border-radius: 0;
  }
</style>
<div class="featured-blog legit-featured-blog featured-blog--{{ section.id }}" data-section-id="{{ section.id }}"
     data-section-type="featured-blog">
    <div class="section-container">
        {% if section.settings.title != blank %}
            <p class="featured-blog__heading section-header__title font-title section-title  text-center"
               data-animate>{{ section.settings.title | escape }}</p>
        {% endif %}
        {%- assign blog = blogs[section.settings.blog] -%}
        {%- assign mobileColumns = 1 -%}

        {% unless blog.size == 1 %}
            {% case section.settings.post_limit %}
                {% when 3 %}
                    {%- assign desktopColumns = 3 -%}
                    {%- assign width = 'medium-up--one-third' -%}
                {% when 2 %}
                    {%- assign desktopColumns = 2 -%}
                    {%- assign width = 'medium-up--one-half' -%}
                {% when 1 %}
                    {%- assign desktopColumns = 1 -%}
                    {%- assign width = 'one-whole' -%}
                {% else %}
                    {%- assign desktopColumns = 3 -%}
                    {%- assign width = 'medium-up--one-third' -%}
            {% endcase %}
        {% endunless %}
        {% capture emptyBlog %}
            <div class="card-list grid" data-desktop-columns="{{ desktopColumns }}"
                 data-mobile-columns="{{ mobileColumns }}">
                <div class="card-list__column grid__item {{ width }}{% if mobileColumns == 2 %} small--one-half{% endif %}">
                    {% for i in (1..section.settings.post_limit) %}
                        <div class="card critical-clear" data-animate>
                            <a class="card__wrapper card--article">
                            {% if section.settings.blog_show_image %}
                            {% if section.settings.post_limit == 1 %}
                            <div class="medium-up--one-half card-list__column--half-left">
                                {% endif %}
                            <div class="card__image-wrapper">
                                {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                                {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                            </div>
                            {% if section.settings.post_limit == 1 %}
                                </div>
                            {% endif %}
                            {% if blog.size == 1 or section.settings.post_limit == 1 %}
                                <div class="medium-up--one-half card-list__column--half-right">
                                    {% endif %}
                                    {% endif %}
                                    <div class="card__info">
                                        <h2 class="card__name font-title">{{ 'homepage.onboarding.blog_title' | t }}</h2>
                                        {% if section.settings.blog_show_excerpt %}
                                            <div class="card__excerpt rte font-description">
                                                {{ 'homepage.onboarding.blog_excerpt' | t }}
                                            </div>
                                        {% endif %}
                                        <span class="card__read-more font-title">
                    {{ 'blogs.article.read_more' | t }}
                                            {% include 'icon-arrow-right' %}
                  </span>
                                    </div>
                                    {% if section.settings.blog_show_image %}
                                    {% if blog.size == 1 or section.settings.post_limit == 1 %}
                                </div>
                                {% endif %}
                                {% endif %}
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endcapture %}

        {% unless blog.articles_count == 0 %}
            <div class="card-list grid" data-desktop-columns="{{ desktopColumns }}" data-mobile-columns="{{ mobileColumns }}" data-grid-style="{{ section.settings.grid_style }}">
                <div class="card-list__column grid__item {{ width }}{% if mobileColumns == 2 %} small--one-half{% endif %}">
                    {% for article in blog.articles limit: section.settings.post_limit %}
                        {% include 'legit-article-card', article: article, grid_style: section.settings.grid_style %}
                    {% endfor %}
                </div>
            </div>
        {% else %}
            {{ emptyBlog }}
        {% endunless %}

        {% if blog == empty %}
            {{ emptyBlog }}
        {% endif %}

        {% if section.settings.show_view_all %}
            <div class="featured-blog__view-all-wrap">
                <a href="https://legitgrails.com/blogs/news"
                   class="font-title main-btn{% if section.settings.use_second_button %} btn--secondary{% endif %}" {% if section.settings.link_target %}  target="_blank"{% endif %} >
                    More Guides
                </a>
            </div>
        {% endif %}

    </div>
</div>
{% schema %}
{
  "name": {
    "en": "Legit partners blog posts"
  },
  "class": "guides-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": {
        "en": "Heading"
      },
      "default": {
        "en": "Blog"
      }
    },
    {
      "id": "blog",
      "type": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": {
        "en": "Posts"
      },
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "blog_show_date",
      "label": {
        "en": "Show date"
      },
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_show_author",
      "label": {
        "en": "Show author"
      },
      "default": false
    },
    {
      "type": "checkbox",
      "id": "blog_show_image",
      "label": {
        "en": "Show cover image"
      },
      "default": false
    },
    {
      "type": "checkbox",
      "id": "blog_show_excerpt",
      "label": {
        "en": "Show excerpt"
      },
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": {
        "en": "Show 'View all' button"
      },
      "default": false
    },
    {
      "type": "checkbox",
      "id": "link_target",
      "label": {
        "en": "Open links in a new window"
      },
      "default": true
    },
    {
      "type": "url",
      "id": "button_link",
      "label": {
        "en": "Button link"
      }
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Legit partners blogs"
      }
    }
  ]
}
{% endschema %}

