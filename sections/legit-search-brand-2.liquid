{% render 'section-legit-search-brand-2-styles' %}
<div class="search-brand">
    <div class="brands-wrap">
    <div class="brands-container">
        {%- for block in section.blocks -%}
            <div id="{{ block.id }}" class="brand-block active" data-type="{{ block.settings.brand_type | downcase }}"
                 data-name="{{ block.settings.title | downcase }}">
                <div class="brand-block_logo"
                     style="background-image: url({{ block.settings.brand_logo | img_url: '400x' }})">
                </div>
                <h2 class="brand-block_title font-title">
                    {{ block.settings.title }}
                </h2>
                {%- unless block.settings.link == blank -%}
                <a class="brand-block__link font-description" href="{{ block.settings.link }}">{{ block.settings.title }}</a>
                {%- endunless -%}
            </div>
        {% endfor %}
    </div>
    </div>
  
</div>

