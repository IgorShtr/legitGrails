      "options": [
        {
          "value": "0",
          "label": "0%"
        },
        {
          "value": "0.1",
          "label": "10%"
        },
        {
          "value": "0.2",
          "label": "20%"
        },
        {
          "value": "0.3",
          "label": "30%"
        },
        {
          "value": "0.4",
          "label": "40%"
        },
        {
          "value": "0.5",
          "label": "50%"
        },
        {
          "value": "0.6",
          "label": "60%"
        },
        {
          "value": "0.7",
          "label": "70%"
        },
        {
          "value": "0.8",
          "label": "80%"
        },
        {
          "value": "0.9",
          "label": "90%"
        },
        {
          "value": "1",
          "label": "100%"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": {
        "en": "Image"
      },
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": {
            "en": "Image"
          }
        },
        {
          "type": "header",
          "content": {
            "en": "Text"
          }
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": {
            "en": "Caption"
          },
          "default": {
            "en": "Talk about your brand"
          }
        },
        {
          "type": "richtext",
          "id": "block_description",
          "label": {
            "en": "Description"
          },
          "default": {
            "en": "<p>Describe your brand</p>"
          }
        },
        {
          "type": "url",
          "id": "link",
          "label": {
            "en": "Link"
          },
          "info": {
            "en": "Optional"
          }
        }
      ]
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Legit Blocks Horizontal"
      },
      "category": {
        "en": "Image"
      },
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
