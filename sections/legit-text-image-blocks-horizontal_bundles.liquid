{% render 'section-legit-text-image-blocks-horizontal_bundles-styles' %}
{% if section.settings.show_overlay %}
    <style>
        .section-steps--{{ section.id }}.section-steps__overlay:before {
            background-color: {{ section.settings.overlay_color }};
            opacity: {{ section.settings.overlay_opacity }};
        }
        .section-steps--{{ section.id }} .legit-step-horizontal__caption,
        .section-steps--{{ section.id }} .section-title,
        .section-steps--{{ section.id }} .section-description,
        .section-steps--{{ section.id }} .legit-step-horizontal__text p {
            color: {{ section.settings.overlay_text }};
        }
    </style>
{% endif %}
<div class="section-steps section-steps--{{ section.id }} {% if section.settings.show_overlay %} section-steps__overlay{% endif %}"
     data-section-id="{{ section.id }}"
     data-section-type="step-template">
    <div class="section-container--{{ section.id }}">
        <div class="steps-heading grid text-center">
            <h2 class="hero__overlay-title section-title font-title" data-animate>{{ section.settings.title }}</h2>
            {% if block.settings.description != blank %}
                <p class="section-description font-description">{{ section.settings.description }}</p>
            {% endif %}
        </div>

        <div class="legit-step-horizontal legit-step-horizontal--{{ section.id }} legit-step-horizontal--{{ section.settings.section_height }}"
             data-section-id="{{ section.id }}" data-section-type="gallery">
            {% for block in section.blocks %}
                <div class="legit-step-horizontal__flex-row legit-step-horizontal__{{ section.blocks.size }}-column">
                    {% if block.settings.image != blank %}
                        <div class="legit-step-horizontal__container">
                            <div class="legit-step-horizontal__item legit-step-horizontal__item--{{ forloop.index }} lazyload" {{ block.shopify_attributes }}
                                 data-bgset="{% include 'bgset', image: block.settings.image %}">
                            </div>
                        </div>
                    {% endif %}
                    <div class="legit-step-horizontal__text" data-animate>
                        {% if block.settings.cta_label != blank %}
                            <p class="legit-step-horizontal__caption font-title">{{ block.settings.cta_label | escape }}</p>
                        {% endif %}
                        {% if block.settings.block_description != blank %}
                            <div class="legit-step-horizontal__description font-description">{{ block.settings.block_description }}</div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if section.blocks.size == 0 %}
            {% include 'no-blocks' %}
        {% endif %}

        {% if section.settings.button_label != blank %}
            <div class="button-container">
                <a href="{{ section.settings.button_link }}"
                   class="font-title main-btn{% if section.settings.use_second_button %} btn--secondary{% endif %} hero__btn">
                    {{ section.settings.button_label }}
                </a>
            </div>
        {% endif %}
    </div>
</div>


{% schema %}
{
