        "en": "Show overlay"
      },
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": {
        "en": "Overlay Color"
      },
      "default": "#242424"
    },
    {
      "type": "color",
      "id": "overlay_text",
      "label": {
        "en": "Text color"
