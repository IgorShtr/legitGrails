<script>
(function () {
  const searchField = document.getElementById('search-brand-input');
  const groupFilterButtons = document.querySelectorAll('.text-filter-buttons [data-type]');
  const categoryFilterButtons = document.querySelectorAll('.filter-buttons [data-type]');
  const brandGroups = Array.from(document.querySelectorAll('.account-bc_search-item'));
  const categorySelect = document.getElementById('category-select');
  const groupSelect = document.getElementById('group-select');
  const typeSelect = document.getElementById('type-select');

  let activeGroup = 'all';
  let activeCategory = 'all';
  let activeType = 'all';
  let searchString = '';

  function normalize(str){ return str.toLowerCase().trim(); }

  function updateBrandVisibility() {
    let visibleGroupCount = 0;

    brandGroups.forEach(group => {
      const groupType = group.getAttribute('data-type').replace('category-', '');
      const groupMatches = activeGroup === 'all' || activeGroup === groupType;

      const brandLinks = Array.from(group.querySelectorAll('a'));
      let hasVisible = false;

      brandLinks.forEach(link => {
        const matchesCategory = activeCategory === 'all' || link.classList.contains(activeCategory);
        const matchesType = activeType === 'all' || link.classList.contains('category-' + activeType); // 👈 filter
        const matchesSearch = normalize(link.textContent).includes(normalize(searchString));

        if (groupMatches && matchesCategory && matchesType && matchesSearch) {
          link.style.display = '';
          hasVisible = true;
        } else {
          link.style.display = 'none';
        }
      });

      group.style.display = hasVisible ? '' : 'none';
      if (hasVisible) visibleGroupCount++;
    });

    const emptyBlock = document.querySelector('.account-bc_search-item-empty');
    if (emptyBlock) emptyBlock.style.display = visibleGroupCount === 0 ? '' : 'none';
  }

  function setActiveButton(activeBtn, btnGroup) {
    btnGroup.forEach(btn => btn.classList.remove('active'));
    activeBtn.classList.add('active');
  }

  groupFilterButtons.forEach(button => {
    button.addEventListener('click', () => {
      activeGroup = button.getAttribute('data-type') || 'all';
      setActiveButton(button, groupFilterButtons);
      syncSelectsFromState();
      updateBrandVisibility();
    });
  });

  categoryFilterButtons.forEach(button => {
    button.addEventListener('click', () => {
      activeCategory = button.getAttribute('data-type') || 'all';
      setActiveButton(button, categoryFilterButtons);
      syncSelectsFromState();
      updateBrandVisibility();
    });
  });

  if (searchField) {
    searchField.addEventListener('input', (e) => {
      searchString = e.target.value;
      updateBrandVisibility();
    });
    searchField.addEventListener('focus', () => searchField.parentElement.classList.add('focused'));
    searchField.addEventListener('blur',  () => searchField.parentElement.classList.remove('focused'));
  }

  function buildSelectFromButtons(selectEl, buttonsNodeList, placeholderText) {
  const opts = [];
  buttonsNodeList.forEach(btn => {
    const label = (btn.textContent || '').trim();
    const value = label.toLowerCase().replace(/\s+/g, '-');
    
    if (!opts.find(o => o.label === label)) {
      opts.push({ value, label, dataType: btn.getAttribute('data-type') || 'all' });
    }
  });

  selectEl.innerHTML = '';
  
  const ph = document.createElement('option');
  ph.value = ''; ph.disabled = true; ph.hidden = true;
  ph.textContent = placeholderText;
  selectEl.appendChild(ph);

  opts.forEach(o => {
    const opt = document.createElement('option');
    opt.value = o.dataType;  
    opt.textContent = o.label; 
    selectEl.appendChild(opt);
  });
}


  buildSelectFromButtons(categorySelect, categoryFilterButtons, 'Category…');
  buildSelectFromButtons(groupSelect, groupFilterButtons, 'Letter…');


  categorySelect.addEventListener('change', () => {
    activeCategory = categorySelect.value || 'all';
    // Reflect into desktop buttons (even if hidden) to keep one source of truth
    const match = [...categoryFilterButtons].find(b => (b.getAttribute('data-type') || 'all') === activeCategory);
    if (match) setActiveButton(match, categoryFilterButtons);
    updateBrandVisibility();
  });

  groupSelect.addEventListener('change', () => {
    activeGroup = groupSelect.value || 'all';
    const match = [...groupFilterButtons].find(b => (b.getAttribute('data-type') || 'all') === activeGroup);
    if (match) setActiveButton(match, groupFilterButtons);
    updateBrandVisibility();
  });

  if (typeSelect) {
    typeSelect.addEventListener('change', () => {
      activeType = typeSelect.value || 'all';
      updateBrandVisibility();
    });
  }

  function syncSelectsFromState() {
    if (categorySelect) {
      const has = [...categorySelect.options].some(o => o.value === activeCategory);
      categorySelect.value = has ? activeCategory : '';
    }
    if (groupSelect) {
      const has = [...groupSelect.options].some(o => o.value === activeGroup);
      groupSelect.value = has ? activeGroup : '';
    }
  }
  
  window.addEventListener('resize', syncSelectsFromState);

  // Initial state (respect pre-marked .active buttons)
  const initialCat = [...categoryFilterButtons].find(b => b.classList.contains('active'));
  const initialGrp = [...groupFilterButtons].find(b => b.classList.contains('active'));
  if (initialCat) activeCategory = initialCat.getAttribute('data-type') || 'all';
  if (initialGrp) activeGroup = initialGrp.getAttribute('data-type') || 'all';
  syncSelectsFromState();
  updateBrandVisibility();
})();
</script>

