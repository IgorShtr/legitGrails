<script>
(() => {
  'use strict';

  // ===== Utilities (shared) =====
  const norm = (s) => (s || '').toLowerCase().trim().replace(/\s+/g, ' ');
  const debounce = (fn, ms=150) => { let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; };

  // Two rows by breakpoints for BRANDS
  function twoRowLimit() {
    const w = window.innerWidth || document.documentElement.clientWidth;
    if (w > 1450) return 10;     // 5/row → 10
    if (w > 1250) return 8;      // 4/row → 8
    if (w > 600)  return 6;      // 3/row → 6
    return 4;                    // 2/row → 4
  }

  // ===== BRANDS: Global "Show more" with last-tile placement =====
  function setupBrandBlock(wrapper) {
    if (!wrapper || wrapper.dataset.brandInit === '1') return;
    const input = wrapper.querySelector('#search-brand-input');
    if (!input) return; // this wrapper is not the brands block
    wrapper.dataset.brandInit = '1';

    const categories = Array.from(wrapper.querySelectorAll('.search-bc_search-item'));
    const emptyBlock = wrapper.querySelector('.search-bc_search-item-empty');
    if (!categories.length) return;

    // Primary category = “Handbags” if present, else first
    const primary =
      categories.find(c => norm(c.querySelector('h2')?.textContent).includes('handbags')) ||
      categories[0];

    let expanded = false;

    const getCards = (cat) =>
      Array.from(cat.querySelectorAll('.search-bc_search-item-brand'))
        .filter(el => !el.hasAttribute('data-global-show-more'));

    function getOrCreateShowMore() {
      let btn = primary.querySelector('[data-global-show-more]');
      if (btn) return btn;
      btn = document.createElement('a');
      btn.href = '';
      btn.setAttribute('data-global-show-more', '1');
      btn.className = 'standart-hover search-bc_search-item-brand block-flex-wrap block-flex-center-center block-gap-20 tac';
      btn.innerHTML = '<span class="body-text w-100">Show more</span>';
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        expanded = true;
        render(input.value || '');
      });
      return btn;
    }

    function renderCollapsed() {
      // Hide non-primary categories
      categories.forEach(cat => { cat.style.display = (cat === primary) ? '' : 'none'; });

      const brandWrap = primary.querySelector('.search-bc_search-item-brands');
      if (!brandWrap) return;

      const cards = getCards(primary);
      const limit = twoRowLimit();

      // Reset all to visible, remove any old Show more
      cards.forEach(c => { c.style.display = ''; });
      brandWrap.querySelector('[data-global-show-more]')?.remove();

      if (cards.length > limit) {
        // Show (limit-1) real cards, and put Show more as the Nth tile
        cards.forEach((c, i) => { c.style.display = i < (limit - 1) ? '' : 'none'; });

        const showMore = getOrCreateShowMore();
        const anchor = cards[limit - 1] || null; // hidden real Nth card
        if (anchor) brandWrap.insertBefore(showMore, anchor);
        else brandWrap.appendChild(showMore);
        showMore.style.display = '';
      } else {
        // Not enough items to need Show more
        brandWrap.querySelector('[data-global-show-more]')?.remove();
      }

      if (emptyBlock) emptyBlock.style.display = cards.length ? 'none' : '';
    }

    function renderExpandedWithQuery(qRaw) {
      const q = norm(qRaw);
      let anyVisible = false;

      // Remove Show more in expanded/search modes
      primary.querySelector('[data-global-show-more]')?.remove();

      categories.forEach(cat => {
        const titleText = norm(cat.querySelector('h2')?.textContent);
        const cards = getCards(cat);

        if (!q) {
          // Expanded without search → show everything
          cards.forEach(c => { c.style.display = ''; });
          cat.style.display = cards.length ? '' : 'none';
          if (cards.length) anyVisible = true;
          return;
        }

        // With search: show matching cards; if none but title matches, show all in that category
        let matchedAny = false;
        cards.forEach(card => {
          const labelText = norm(card.querySelector('span')?.textContent);
          const matched = labelText.includes(q);
          card.style.display = matched ? '' : 'none';
          if (matched) matchedAny = true;
        });

        if (!matchedAny && titleText.includes(q)) {
          cards.forEach(c => { c.style.display = ''; });
          matchedAny = cards.length > 0;
        }

        cat.style.display = matchedAny ? '' : 'none';
        if (matchedAny) anyVisible = true;
      });

      if (emptyBlock) emptyBlock.style.display = anyVisible ? 'none' : '';
    }

    function render(qRaw) {
      const hasQuery = !!norm(qRaw);
      if (!expanded && !hasQuery) {
        renderCollapsed();
      } else {
        renderExpandedWithQuery(qRaw);
      }
    }

    // Hook up events
    input.addEventListener('input', (e) => render(e.target.value));
    const onResize = debounce(() => {
      if (!expanded && !norm(input.value)) renderCollapsed();
      else renderExpandedWithQuery(input.value || '');
    }, 150);
    window.addEventListener('resize', onResize);

    // First paint
    render('');
  }

  // ===== CODES: Per-category filtering + empty toggle =====
  function setupCodesBlock(wrapper) {
    if (!wrapper || wrapper.dataset.codesInit === '1') return;
    const input = wrapper.querySelector('#search-code-input');
    if (!input) return; // this wrapper is not the codes block
    wrapper.dataset.codesInit = '1';

    const codeCategories = Array.from(
      wrapper.querySelectorAll('.search-bc_search-item')
    ).filter(cat => cat.querySelector('.search-bc_search-item-codes'));

    const getCodeText = (item) => {
      const t1 = item.querySelector('.search-bc_search-item-code-text p')?.textContent;
      const t2 = item.querySelector('.search-bc_search-item-code-code p')?.textContent; // alternative class
      return norm(t1 || t2 || '');
    };

    function applyFilter(qRaw) {
      const q = norm(qRaw);
      codeCategories.forEach((cat) => {
        const items = Array.from(cat.querySelectorAll('.search-bc_search-item-code'));
        const emptyBlock = cat.querySelector('.search-bc_search-item-empty');

        let visibleCount = 0;

        items.forEach((item) => {
          if (!q) {
            item.style.display = '';
            visibleCount++;
            return;
          }
          const yearText = norm(item.querySelector('.search-bc_search-item-code-year p')?.textContent);
          const codeText = getCodeText(item);
          const match = yearText.includes(q) || codeText.includes(q);
          item.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });

        if (emptyBlock) emptyBlock.style.display = (visibleCount === 0) ? '' : 'none';
      });
    }

    input.addEventListener('input', (e) => applyFilter(e.target.value));
    applyFilter(input.value || '');
  }

  // ===== Initialize BOTH blocks safely (no collisions) =====
  document.querySelectorAll('.search-bc_wrapp').forEach((wrap) => {
    if (wrap.querySelector('#search-brand-input')) setupBrandBlock(wrap);
    if (wrap.querySelector('#search-code-input'))  setupCodesBlock(wrap);
  });

})();
</script>


