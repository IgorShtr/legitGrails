  <!-- Cal inline embed code ends -->
            </div>
            <p class="tiny-text w-100 ivory-text tac">
                    For general questions that don’t require a call, please use our 24/7 live chat or email us at <a style="text-decoration: underline;color: #F24F14;" href="mailto:support@legitgrails.com">support@legitgrails.com</a>
                </p>
        </div>
    </div>
</div>

{% schema %}
  {
    "name": "Schedule a call",
    "class": "schedule-call",
    "settings": []
  }
{% endschema %}