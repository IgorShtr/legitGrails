                  </svg>
               </a>
            </div>
         </div>
         {%- endif -%}
      {% endfor %}
    </div>
    <div class="block-flex-wrap block-flex-center-center block-gap-10 w-100">
      <a href="https://legitgrails.com/pages/verified-partners" class="rebranding_btn rebranding_btn-main">View all</a>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Verified Partners",
    "class": "rebranding-section",
    "settings": []
  }
{% endschema %}