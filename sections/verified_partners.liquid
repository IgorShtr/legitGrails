                  </svg>
                  <p class="body-text">{{ page.metafields.custom.verified_partner_location }}</p>
               </div>
             </div>
            <div class="verified-partners_card-btns block-flex-wrap block-gap-10 w-100">
               <a href="{{ page.url }}" class="verified-partners_card-btn-more rebranding_btn w-100">Learn more</a>
