<style>
  .verified-partners_card {
    border-radius: 11px;
    border: 1px solid #D4D4D4;
    padding: 30px 20px;
    height: 524px;
  }
  .verified-partners_card-image-wrapp {
    height: 200px;
  }
  .verified-partners_card-image {
height: auto;
max-height: 100%;
width: auto;
  }
  .verified-partners_card {
    width: calc(33.33334% - 13.33334px);
  }
  .verified-partners_card-description {
    overflow: hidden;
    text-overflow: ellipsis;
    -webkit-line-clamp: 4;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
  }
.verified-partners_card-location p {
max-width: calc(100% - 100px);
text-align: center;
}
  .verified-partners_card-location svg {
    margin-top: -1px;
  }
  a.verified-partners_card-btn-website {
    min-width: auto;
    width: 84px;
    padding: 12px 28px;
    height: 50px;
  }
  a.verified-partners_card-btn-more {
    width: calc(100% - 94px);
    min-width: auto;
  }
  a.verified-partners_card-btn-website svg {
    height: 22px;
  }
  @media(max-width: 1250px) {
    .verified-partners_card {
      width: calc(50% - 10px);
    }
  }
  @media(max-width: 750px) {
    .verified-partners_card {
      width: 100%;
      height: max-content;
    }
    .verified-partners_card-image-wrapp {
      height: 130px;
    }
    a.verified-partners_card-btn-website {
      width: 80px;
    }
    a.verified-partners_card-btn-more {
      width: calc(100% - 90px);
    }
  }
</style>

<div class="rebranding_container">
  <div class="block-flex-wrap block-gap-40 block-flex-center-center">
    <div class="block-flex-wrap w-100 block-flex-center-center">
      <h2 class="h2-heading-ss tac">Explore <span class="h2-heading-pp">Verified Stores</span> Worldwide</h2>
    </div>
    <div class="block-flex-wrap w-100 block-flex-center-center block-gap-20">
      {% for page in pages %}
        {%- if page.metafields.custom.verified_partner_main_landing == true -%}
         <div class="verified-partners_card block-flex-wrap block-gap-30 block-flex-center-center tac">
           <div class="verified-partners_card-image-wrapp block-flex-wrap block-flex-center-center">
             <img class="verified-partners_card-image" src="{{ page.metafields.custom.verified_partner_logo.value | image_url }}">
           </div>
           <div class="w-100 block-flex-wrap block-gap-20 block-flex-center-center">
               <h3 class="h3-heading-pp w-100 tac">{{ page.title }}</h3>
               <p class="body-text w-100">LegitGrails client since: {{ page.metafields.custom.verified_partner_verified_since }}</p>
               <div class="w-100 verified-partners_card-location block-flex-wrap block-flex-start-center block-gap-10">
                  <svg width="18" height="24" viewBox="0 0 18 24" fill="none" xmlns="http://www.w3.org/2000/svg">
