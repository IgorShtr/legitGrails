{%- assign image_crop = true -%}

{% if section.settings.image_crop == 'circle' or section.settings.image_crop == 'square' %}
    {%- assign image_crop = true -%}
{% endif %}

<style>
  .text-brown {
    color: #CDAB71;
  }
    .row-styled--{{ section.id }} {
    {% if section.settings.background_color != blank %}
        background-color: {{ section.settings.background_color }};
    {% elsif section.settings.background_color == blank and image_crop %}
        background-color: {{ settings.color_secondary_bg }};
    {% endif %}
    }

    {% if image_crop %}
    {% comment %}
    @media screen and (min-width: 750px) {
        .feature-row--{{ section.id }} .feature-row__image-wrapper {
            background-color: {{ section.settings.background_color | color_lighten: 5 }};
        }
    }
    {% endcomment %}
    {% endif %}
    .feature-row__item.feature-row__image-wrapper-styled {
        padding: 0px 15px;
    }
  .feature-row--{{ section.id }} .feature-row__btn {
        margin-top: 0;
    }
  .feature-row--{{ section.id }} .feature-row__text-wrap-styled {
        padding-top: 0;
    }
    @media (min-width: 1240px) {
      .feature-row__image-wrapper-styled .feature-row__image-styled {
          height: 600px;
      }
    }
  @media only screen and (max-width: 749px) {
    .feature-row__text.feature-row__text-styled {
        padding: 0 15px 60px 15px!important;
    }
    .feature-row__item.feature-row__image-wrapper-styled {
        padding: 10px 15px 0px 15px;
    }
    
    
    .feature-row--{{ section.id }} .feature-row__text-styled .section-description {
        margin-bottom: 25px;
        margin-top: 20px;
    }
  }

  @media(max-width: 500px) {
    .feature-row--{{ section.id }} .feature-row__image-wrapper-styled .feature-row__image-styled {
    height: 350px;
    }
  }
</style>

{% if section.settings.image != blank %}
    <style>
        .feature-row__image--{{ section.id }} {
            background-position: {{ section.settings.alignment }};
        }
    </style>
{% endif %}

{% capture image_layout %}
    <div class="feature-row__item feature-row__image-wrapper feature-row__image-wrapper-styled">
        {% if section.settings.image != blank %}
            <div class="feature-row__image-styled feature-row__image--{{ section.id }}" style="background-image: url({{ section.settings.image | img_url: 'master' }})"></div>
            <noscript>
                <div class="feature-row__image-styled feature-row__image--{{ section.id }}" style="background-image: url({{ section.settings.image | img_url: 'master' }})"></div>
            </noscript>
        {% else %}
            <div class="feature-row__image feature-row__image--{{ section.id }}">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {% endif %}
    </div>
{% endcapture %}

<div class="feature-row feature-row--{{ section.id }} feature-row--{{ section.settings.size }} {% if section.settings.mobile_layout == 'bottom' %} feature-row-mobile--bottom {% endif %}  row-styled--{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="feature-row">
    {% if section.settings.desktop_layout == 'left' %}
        {{ image_layout }}
    {% endif %}

    <div class="feature-row__item feature-row__text text-white feature-row__text-styled">
        <div class="feature-row__text-wrap-styled">
        {% if section.settings.title != blank %}
            <h2 class="section-title" data-animate>
                <span class="text-white font-title">{{ section.settings.text_styled }}</span><br>
                <span class="text-brown font-title">{{ section.settings.title }} </span> </h2>
        {% endif %}
        {% if section.settings.text != blank %}
            <div class="rte-setting featured-row__subtext section-description text-white font-description">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
            <div class="main-btn-wrap">
                <a href="{{ section.settings.button_link }}" class="font-title main-btn {% if section.settings.use_second_button %} btn--secondary{% endif %} feature-row__btn">
                    {{ section.settings.button_label }}
                </a>
            </div>
        {% endif %}
        </div>
    </div>

    {% if section.settings.desktop_layout == 'right' %}
        {{ image_layout }}
    {% endif %}
</div>

