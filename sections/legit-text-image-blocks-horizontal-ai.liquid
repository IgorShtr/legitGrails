{% render 'section-legit-text-image-blocks-horizontal-ai-styles' %}
{% if section.settings.show_overlay %}
    <style>
        .section-steps--{{ section.id }}.section-steps__overlay:before {
            background-color: {{ section.settings.overlay_color }};
            opacity: {{ section.settings.overlay_opacity }};
        }
        .section-steps--{{ section.id }} .legit-step-horizontal__caption,
        .section-steps--{{ section.id }} .section-title,
        .section-steps--{{ section.id }} .section-description,
        .section-steps--{{ section.id }} .legit-step-horizontal__text p {
            color: {{ section.settings.overlay_text }};
        }
    </style>
{% endif %}
<div class="section-steps section-steps--{{ section.id }} {% if section.settings.show_overlay %} section-steps__overlay{% endif %}"
     data-section-id="{{ section.id }}"
     data-section-type="step-template">
    <div class="section-container--{{ section.id }}">
        <div class="steps-heading grid text-center">
            <h2 class="hero__overlay-title section-title font-title" data-animate>How It Works: Start Your Authentication</h2>
        </div>

        <div class="legit-step-horizontal legit-step-horizontal--{{ section.id }} legit-step-horizontal--{{ section.settings.section_height }}"
             data-section-id="{{ section.id }}" data-section-type="gallery">
                <div class="legit-step-horizontal__flex-row legit-step-horizontal__{{ section.blocks.size }}-column">
                        <div class="legit-step-horizontal__container">
                            <div class="legit-step-horizontal__item legit-step-horizontal__item--{{ forloop.index }}"
                                 style="background-image: url('{{ "steps-1.webp" | asset_url }}')">
                            </div>
                        </div>
                    <div class="legit-step-horizontal__text" data-animate>
                            <p class="legit-step-horizontal__caption font-title">Upload Photos</p>
                            <div class="legit-step-horizontal__description font-description"><p>Begin by uploading images of your item.</p></div>
                    </div>
                </div>
              <div class="legit-step-horizontal__flex-row legit-step-horizontal__{{ section.blocks.size }}-column">
                        <div class="legit-step-horizontal__container">
                            <div class="legit-step-horizontal__item legit-step-horizontal__item--{{ forloop.index }}"
                                 style="background-image: url('{{ "steps-2.webp" | asset_url }}')">
                            </div>
                        </div>
                    <div class="legit-step-horizontal__text" data-animate>
                            <p class="legit-step-horizontal__caption font-title">We Handle It</p>
                            <div class="legit-step-horizontal__description font-description"><p>Our expert team, alongside advanced AI, reviews your item thoroughly.</p></div>
                    </div>
                </div>
              <div class="legit-step-horizontal__flex-row legit-step-horizontal__{{ section.blocks.size }}-column">
                        <div class="legit-step-horizontal__container">
                            <div class="legit-step-horizontal__item legit-step-horizontal__item--{{ forloop.index }}"
                                 style="background-image: url('{{ "steps-3.webp" | asset_url }}')">
                            </div>
                        </div>
                    <div class="legit-step-horizontal__text" data-animate>
                            <p class="legit-step-horizontal__caption font-title">Receive Your Certificate</p>
                            <div class="legit-step-horizontal__description font-description"><p>You’ll receive the results via email, including a unique certificate of authenticity.</p></div>
                    </div>
                </div>
        </div>
    </div>
</div>


