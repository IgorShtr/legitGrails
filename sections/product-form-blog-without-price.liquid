{% if template contains 'article' %}
    {%- assign product = all_products[article.metafields.custom.product] -%}
{% elsif template contains 'page' %}
    {%- assign product = all_products[page.metafields.custom.product] -%}
{% elsif template contains 'blogs' %}
    {%- assign product = all_products[blogs.metafields.custom.product] -%}
{% endif %}
{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign current_variant_sale = false -%}
{% if current_variant.compare_at_price > current_variant.price %}
    {%- assign current_variant_sale = true -%}
{% endif %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}
{% assign items = product.metafields.custom.form_settings.value %}
{% render 'section-product-form-blog-styles-min' %}
{% render 'uploadcare-styles' %}
<div id="product-card-container" {% if template contains 'article' %} style="display: none" {% endif %}>
    <div class="product-card">
      <div class="guides-block">
<div class="guides-block_item">
<p class="guides-block_item-title">Verify any branded item in 3&nbsp;simple steps</p>
<div class="guides-block_item-steps">
<div class="guides-block_item-step"><span> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_round.svg?v=1702460484" loading="lazy" alt=""> </span>
<p>Choose response time &amp; upload photos</p>
</div>
<div class="guides-block_item-step"><span> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_round.svg?v=1702460484" loading="lazy" alt=""> </span>
<p>Wait for AI & Human Experts decision</p>
</div>
<div class="guides-block_item-step"><span> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_checkmark.svg?v=1702460484" loading="lazy" alt=""> </span>
<p>Get the verdict and personal certificate</p>
</div>
</div>
</div>
<div class="guides-block_item guides-block_item-product">
        <p class="product_card-title font-title" itemprop="name">{{ product.title }}</p>
        {% unless article.tags contains "remove-price" %}
          <p class="font-description product_card-price{% if current_variant_sale %} product__price--sale{% endif %}" aria-live="polite">
            <span class="product__current-price">{{ current_variant.price | money }}</span>
            </p>
          {% endunless %}
        

        {% form 'product', product, class: 'product-form' %}
            {% unless current_variant.available %}
                {% assign button_text = 'products.product.sold_out' | t %}
            {% else %}
                {% assign button_text = 'products.product.add_to_cart' | t %}
            {% endunless %}
            {% if template.handle contains 'product' %}
                {% unless product.has_only_default_variant %}
                    {% for option in product.options_with_values %}
                        <div class="product-form__item supports-js">
                            {% if option.name != 'default' %}
                                <label class="font-description single-option-selector__label{% unless section.settings.show_variant_labels %} single-option-selector__label--hidden{% endunless %}"
                                       for="{{ option.name | escape }}">{{ option.name }}</label>
                            {% endif %}
                            <select id="{{ option.name | escape }}" name="{{ option.name | escape }}"
                                    class="single-option-selector" data-option-input>
                                {% for value in option.values %}
                                    {% assign safeValue = value | replace: '"', '&quot;' %}
                                    <option value="{{ safeValue }}"
                                            {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    {% endfor %}
                {% endunless %}
                <label>
                    <select name="id" class="product-form__master-select supports-no-js" data-master-select>
                        {% for variant in product.variants %}
                            {% if variant.available %}
                                <option {% if variant == product.selected_or_first_available_variant %} selected="selected" {% endif %}
                                        data-sku="{{ variant.sku }}" value="{{ variant.id }}">{{ variant.title }}
                                    - {{ variant.price | money_with_currency }}</option>
                            {% else %}
                                <option disabled="disabled">
                                    {{ variant.title }} - {{ 'products.product.sold_out' | t }}
                                </option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </label>

            {% endif %}

            <div class="variant-list ">
                {% for product_option in product.options_with_values %}
                    <p class="pro-option-name product_card-answear font-description">Results in:</p>
                {% endfor %}
                <div class="product-variants infiniteoptions product_card-radio">
                    {% for variant in product.variants %}
                        {% capture random %}{{ 'now' | date: "%09N" }}{% endcapture %}
                        <div class="radio-options font-description">
                            {% if variant.available %}
                                <label class="radio radio-wrap" for="radio_{{ random }}">
                                    {{ variant.title | escape }}
                                    {% if variant.price < variant.compare_at_price %}
                                        <del>{{ variant.compare_at_price | money }}</del>{% endif %}
                                    <input type="radio" name="id" id="radio_{{ random }}" value="{{ variant.id }}"
                                           data-price="{{ variant.price | money }}"
                                           data-variant-title="{{ variant.title }}"
                                           {% if forloop.first %}checked="true"{% endif %} class="radio-option"/>
                                    <div class="checkmark"></div>
                                </label>

                            {% else %}
                                <label for="radio_{{ random }}" class="radio">
                                    {{ variant.title }} is temporarily unavailable
                                    <input type="radio" name="id" value="{{ variant.id }}" id="radio_{{ random }}"
                                           disabled="disabled"/>
                                    <div class="checkmark"></div>
                                </label>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
            <div class="product_card-btns">
                <div class="redirect-checkout-btn">
                    <input type="hidden" name="redirect" id="redirect-addtocart-btn" data-productid="{{ product.id }}"
                           class="product-select" value="{{ product.selected_or_first_available_variant.id }}"
                           data-variant-title="{{ product.selected_or_first_available_variant.title }}"/>
                    <input type="submit" value="Add To Cart" class="hidden product_card-cart"/>
                    <div class="btn-submit-container">
                        <div class="cart-notification"></div>
                        <button id="cart___submit" class="font-title custom-cart-button">Add to cart</button>
                    </div>
                </div>
                <p class="product__notification text-small text-center font-description" data-cart-notification></p>
            </div>
            <div class="uploadcare-attributes hidden"></div>
        {% endform %}
        <div class="uploadcare">
            <p class="authenticate-btn font-title" style="">Upload Photos</p>
        </div>
          <!--{% if product.tags contains 'partner-link-guide' %}
           <a class="legit-link partner-link" href="https://legitgrails.com/pages/partner-with-legitgrails">aneed multiple authentications?</a>
          {% endif %}-->
  </div>
<div class="guides-block_item">
<p class="guides-block_item-title">Authenticate your branded items with Experts & AI</p>
<div class="guides-block_item-advantages">
<div class="guides-block_item-advantages-reviews">
