          </svg>
        </div>
        <p class="guides-block_item-advantages-reviews-desc">rated 4.7/5.0 by more than 100,000 customers</p>
        <div class="guides-block_item-advantages-reviews-imgs">
          <div class="guides-block_item-advantages-reviews-img">
            <img src="//legitgrails.com/cdn/shop/t/168/assets/reviews_klients-1.webp?v=74878100532075713011746166976">
          </div>
          <div class="guides-block_item-advantages-reviews-img">
            <img src="{{ "reviews_klients-2.webp" | asset_url }}" loading="lazy">
          </div>
          <div class="guides-block_item-advantages-reviews-img">
            <img src="{{ "reviews_klients-3.webp" | asset_url }}" loading="lazy">
          </div>
          <div class="guides-block_item-advantages-reviews-img">
            <img src="{{ "reviews_klients-4.webp" | asset_url }}" loading="lazy">
          </div>
          <div class="guides-block_item-advantages-reviews-img">
            <img src="{{ "reviews_klients-5.webp" | asset_url }}" loading="lazy">
          </div>
        </div>
      </div>
<div class="guides-block_item-advantages-featured">
<p class="guides-block_item-advantages-featured-desc">featured by</p>
<div class="guides-block_item-advantages-featured-images"><img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_rapaport.svg?v=1702460484" loading="lazy" alt=""> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_insider.svg?v=1702460484" loading="lazy" alt=""> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_forbes.svg?v=1702460484" loading="lazy" alt=""> <img src="https://cdn.shopify.com/s/files/1/0094/6307/0798/files/guide-block_nice.svg?v=1702460484" loading="lazy" alt=""></div>
</div>
</div>
</div>
</div>
    </div>
    </div>
<div class="hidden" id="product-data">{{ product.id }}</div>

